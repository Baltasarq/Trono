!---------------------------------------------------------------------
! Lucius, en el almenar
!---------------------------------------------------------------------

Responde luciusRespondonAntesMerlin
private
	elementos
		"Partid cuanto antes, amigo mÌo"
		"DebÈis partir lo antes posible"
		"Adelante. Encontrar a MerlÌn. Contamos con vos."
		"Me preocupa que a˙n estÈis aquÌ... øDese·is cumplir la voluntad del Rey o no?"
		"Quiz·s para cuando os pong·is en marcha sea demasiado tarde ya..."
		"°Partid presto!"
		"Adelante, amigo mÌo"
;

Responde luciusRespondonDespuesMerlin
private
	elementos
		"ø°A quÈ esperas Ulfius...?! Quiz·s el futuro de todo el reino depende de que
			             vayas a hablar con el Rey..."
		"DebÈis hablar con el Rey lo antes posible"
		"°Enhorabuena...! Pero ahora debÈis comunicarle las albricias al Rey."
		"No esperÈis m·s, Ulfius."
		"El sitio de Cornualles contin˙a... °el tiempo apremia!"
		"°Partid presto!"
		"Adelante, amigo mÌo, hablad con el Rey"
;

ServicioRey Lucius ALMENAR
	! Estado = 0 A˙n no ha hablado con Ulfius
	! Estado = 1 Ha hablado con Ulfius
	! Estado = 2 Ulfius ha completado la misiÛn (haya hablado con Èl o no)
	! Estado = 3 Ulfius ha completado la misiÛn y ha hablado con Èl
with
	elNombre "Lucius",
	nombre_corto "Lucius",
	nombre 'Lucius' 'amigo' 'soldado' 'guardia' 'guarda',
	descripcion [;
		self.ServicioRey::descripcion();
		"...adem·s, Lucius es un gran amigo tuyo, que ha compartido contigo todo tipo
		 de penalidades.";
	],
    cambiarEstado [;
		if ( self.estado < 2
		  && jugador.fueMerlinEncontrado() )
		{
			self.estado = 2;
		}
    ],
	conversacion [;
		if ( jugador.esInvisible() ) {
			jugador.decir( "Lucius..." );
			print (_El) self, " mira a derecha e izquierda...^";
			self.decir( "øSois vos, Ulfius?... øest·is jugando con las pociones de MerlÌn?
			             ...os creÌa m·s maduro, la verdad..." );
			rtrue;
		}

		if ( self.estado == 0 )
		{
			jugador.decir( "Hola, Lucius, amigo." );
			self.decir( "Hola, Ulfius, øquÈ tal?." );

			jugador.decir( "Debo irme. El rey me ha encargado una importante misiÛn..." );
			jugador.decir( "aunque creo que es m·s importante para Èl mismo que para el reino..." );
			jugador.decir( "no lo sÈ..." );

			self.decir( "Comprendo. øTiene algo que ver, quiz·s, Lady Ingrain, en todo Èsto?" );
			jugador.decir( "°SÌ, eso es...!øCÛmo lo sabÈis?" );

			self.decir( "Vos habÈis vuelto hace muy poco de vuestra expediciÛn de castigo contra los sajones,
			             pero las cosas han estado muy revueltas por aquÌ.
			             El Rey ha puesto sitio al castillo de Cornualles."
			);

			jugador.decir( "SÌ, ya lo habÌa oÌdo. El mismo rey acaba de confirm·rmelo ahora mismo." );
			jugador.decir( "°Cornualles sitiado...! Espero que salgamos con bien de Èsto, amigo mÌo...
			               a mi modesto entender, ya nos llega con los sajones...
			               espero que el rey sepa lo que hace."
			);

			self.decir( "El seÒor os oiga, amigo mÌo." );

			jugador.decir( "...en cualquier caso, debo encontrar a MerlÌn, al parecer, al norte de aquÌ." );
			self.decir( "Los caminos no son seguros... est·n llenos de sajones..." );
			jugador.decir( "...a mÌ me lo vais a contar..." );

			self.decir( "IrÈis solo, asÌ que yo en vuestro lugar llevarÌa una armadura ligera, y no llevarÌa caballo." );
			self.decir( "Ya sabÈis cÛmo es el terreno... al ir sÛlo, irÈis mejor a pie y con el mÌnimo de equipamiento." );
			self.decir( "Recordad tambiÈn llevar comida." );

			jugador.decir( "Gracias por todo, amigo, nos veremos pronto." );
			self.decir( "Mucha suerte en vuestra misiÛn, amigo mÌo." );

			self.estado++;
		}
		else
		if ( self.estado == 1 )
		{
			self.decir( luciusRespondonAntesMerlin.dev_msg()	);
		}
		else
		if ( self.estado == 2 )
		{
			jugador.decir( "°Hola, Lucius!" );
			self.decir( "°Hola, Ulfius!" );

			jugador.decir( "°Finalmente, encontrÈ a MerlÌn!" );
			self.decir( "°Estupendo Ulfius...! Quiz·s ahora termine todo Èsta locura..." );
			self.decir( "Debes ir a hablar con el Rey de inmediato... °no te entretengas m·s, Ulfius!" );

			jugador.decir( "AsÌ lo hare." );

			self.estado++;
		}
		else
		if ( self.estado == 3 )
		{
			self.decir( luciusRespondonDespuesMerlin.dev_msg()	);
		}
	]
has propio;

