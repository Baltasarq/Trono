		"Lo siento, Ulfius, pero no puedes irte. El Rey quiere hablar contigo."
		"Ulfius, recuerda que el Rey te mandÛ llamar..."
		"Lo siento, Ulfius, no podemos dejarte marchar... debes hablar con el Rey Uther."
		"Hablar·s con el Rey, Ulfius, quieras o no."
;

respondeUnaVez rukusDice
with
	elementos
		"Andando, muchacho..."
		"Ser· posible, lo que nos haces trabajar... °tan temprano!"
		"°Camina, felÛn!"
		"Maldita sea, °andando!"
;

ServicioRey Rufus PASILLO_PRINCIPAL
with
	elNombre "Rufus",
	nombre_corto "Rufus",
	nombre 'Rufus' 'guardia' 'guarda' 'soldado' 'guardias' 'guardas' 'soldados',
	cambiarEstado [;
		if ( localizacion == PASILLO_PRINCIPAL
		  && ~~( uther.fueMisionEncomendada() ) )
		{
			self.decir( rufusDice.dev_msg() );
			rukus.decir( rukusDice.dev_msg() );

			print "^^Rukus te da un empujÛn, mientras muestra una sonrida burlona...
			       es obvio que no le caes bien,
			       aunque no puedes recordar ning˙n motivo.^";
			jugadorA( SALA_DEL_TRONO, 2 );
			print "^^VolvÈis a la sala del trono en compaÒÌa de Rukus y Rufus";
			wait( "...^" );
			print "^...Rukus y Rufus hacen una reverencia y se retiran.^^";
		}
	],
	conversacion [;
		jugador.decir( "Hola, Rufus" );

		if ( jugador.esInvisible() ) {
			print (_El) self, " mira a derecha e izquierda...^";
			self.decir( "øUlfius?" );
			rtrue;
		}

		self.decir( "Hola, Ulfius" );
		self.decir( "Espero que todo Èsto acabe bien. Mucha suerte." );
	]
has propio;

ServicioRey Rukus PASILLO_PRINCIPAL
with
	determinante "a",
	elNombre "Rukus",
