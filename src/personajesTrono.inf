#ifdef TARGET_GLULX;
Constant ESCR_PRIMERA_LETRA 4;
#endif;
#ifdef TARGET_ZCODE;
Constant ESCR_PRIMERA_LETRA 2;
#endif;

Array up string  "ABCDEFGHIJKLMNOPQRSTUVWXYZ¡…Õ”⁄—";
Array low string "abcdefghijklmnopqrstuvwxyz·ÈÌÛ˙Ò";
Array escr_buffer_lib --> 1024;

[ lower ch i toret;
	toret = ch;


	for(i = 1:i < up->0: ++i) {
		if ( up->i == ch ) {
			toret = low->i;
		}
	}

	return toret;
];

[ imprimeCadenaMinusculas s i lon;
	lon = s.print_to_array( escr_buffer_lib );

	! Visualizar las letras una a una
	for(i = 0: i < ( lon + ESCR_PRIMERA_LETRA): ++i) {
		print lower( escr_buffer_lib->i );
	}
];

class Personaje
with
	sinCambioLinea "",
	conCambioLinea "^",
    estado 0,
    elNombre "Personaje",
    articulo "a",
	pasaANombrePropio [;
		give self propio;
	],
	cabecera [cr;
		if ( cr == nothing ) {
			cr = self.sinCambioLinea;
		}

		s_bold();
        print (string) self.elNombre;
        s_normal();
		print (string) cr;
	],
	piensa [s;
		print "^";
		self.cabecera();
        print " piensa: ~";
		s_underline();
        print (string) s;
        s_normal();
        print "~";
	],
    decir [s;
        self.cabecera();
        print ": ~";
		s_underline();
        print (string) s;
        s_normal();
        print "~";
		wait( "^...^" );
    ],
	antes [;
		hablar:
			self.conversacion();
			rtrue;
		responder, preguntar, orden:
			print (s_underline) "Para hablar con alguien (p.ej. 'x'), utiliza 'HABLA CON x'";
			rtrue;
	],
has animado;

! ------------------------------ Personajes que venden algo --------------------------
class Vendedor
class Personaje
private
	vendido false,
with
	objetoAVender Nothing,
	precio 0,
	reaccionar_antes [;
	        dar:
	            if ( otro == self
	              && uno  == bolsa )
	            {
	                <<comprar self Nothing>>;
	            }
	],
	antes [;
		comprar:

			if ( jugador.esInvisible() ) {
				print "Me temo que ", (_el) self," no os ve.";
				rtrue;
			}

			if ( otro ~= Nothing
			  && otro ~= self.objetoAVender )
			{
				if ( self.objetoAVender == Nothing
				  || self.objetoAVender in limbo )
				{
					<<comprar self>>;
				}

				print "Lo que realmente vende ", (el) self, " es ", (el) self.objetoAVender, ".^";
				rtrue;
			}

			if ( self.objetoAVender ~= Nothing )
			{
				if ( bolsa in jugador
				  && bolsa.getNumMonedas() >= self.precio )
				{
					self.cabecera();
					print " os da ", (el) self.objetoAVender, " a cambio de ",
					      self.precio, " monedas de oro.";

					bolsa.quitarMonedas( self.precio );
					move self.objetoAVender to jugador;
					give self.objetoAVender ~oculto;
					self.objetoAVender = Nothing;
					self.vendido = true;
				}
				else self.decir( "Me temo que no tenÈis dinero para comprar, seÒor..." );
			}
			else {
				if ( self.vendido )
						self.decir( "No creo poder volver a vendÈroslo, mi seÒor..." );
				else 	print (_El) self, " no parece interesado en venderos nada.^";
			}

			rtrue;
	]
;

! ----------------------------- Ladrones -----------------------------
class Ladron
class Personaje
with
	nombre 'ladron' 'ladrones',
	articulos "Un" "El" "el",
	enEntrada false,
	descripcion [;
		self.cabecera();
		print "^Es un ser miserable y probablemente despreciable. Sus ropas no sÛlo son humildes,
		        sino que est·n, adem·s, sucias y desgarradas.^";
	],
	antes [;
		atacar:
			self.decir( "°Maldito caballerucho!" );
			banderafin = 1;
			"PodrÌais luchar contra varios caballeros, pero no contra varios varios
			 ladronzuelos sin honor y sin escr˙pulos.^
			 Me temo que...";

	],
	cambiarEstado [;
		if ( ( localizacion == CAMINO_NORESTE
		    || localizacion == LAGO )
		 &&  self in limbo
		 &&  ~~self.enEntrada )
		{
			self.secuenciaEntrada();
		}
		else
		if ( self notin localizacion
		  && self notin limbo
		  && ~~self.enEntrada )
		{
			move self to limbo;
		}
	],
	secuenciaEntrada [ estaDicho x;
		! Se ha visualizado el mensaje ya ?
		estaDicho = false;
		objectloop ( x ofclass Ladron ) {
			if ( x.enEntrada ) {
				estaDicho = true;
			}
		}

		! Preparar la entrada del personaje en acciÛn
		self.enEntrada = true;
		arrancarReloj( self, 2 );

		! Visualizar mensaje ?
		if ( ~~estaDicho ) {
			print "^Notas algunos ruidos entre los ·rboles...^";
			if ( stolinius.yaHaSidoRobado() ) {
				print "°...Dios mÌo!øSer·n ellos de nuevo?^";
			}
		}
	],
	tiempo_restante 0,
	tiempo_agotado [;
		self.enEntrada = false;

		if ( localizacion == CONTINUACION_DEL_CAMINO
		  || localizacion == CAMINO_NORESTE
		  || localizacion == LAGO )
		{
			move self to localizacion;
			self.hazEntrada();
		}
	],
	hazEntrada [;
		self.estado = 0;
		self.cabecera();
		" aparece de entre los ·rboles, amenazadoramente, empuÒando un cuchillo.";
	],
	conversacion [;
		if ( jugador.esInvisible() ) {
			jugador.decir( "Buen hombre..." );
			print (_El) self, " mira a derecha e izquierda...^";
			self.decir( "Jefe, yo sigo sin verlo, no sÈ cÛmo lo haces." );
			stolinius.decir( "Por eso yo soy el jefe, truh·n..." );
			rtrue;
		}

		jugador.decir( "Buen hombre, yo..." );
		self.decir( "°øBuen hombre, dices...!? Pero... øes que no ves a quÈ me dedico?" );
		print "^Unas sonoras carcajadas coreadas por el resto de maleantes hacen eco en la bÛveda arbÛrea.";
	]
;

!---------------------------------------------------------------------
! Ulfius, nuestro hÈroe
!---------------------------------------------------------------------

Personaje Ulfius SALA_DEL_TRONO
		! Estado 0 - Debes buscar a Merlin
		! Estado 1 - Merlin encontrado, debes volver con Uther
		! Estado 2 - Guiando a Uther por el castillo de Cornualles
		! Estado 3 - MisiÛn cumplida, sÛlo resta volver a donde est· MerlÌn.
private
	numDia 1,
	invisible false,
with
	elNombre "Ulfius",
	estaEnEpilogo [;
	  return ( localizacion == TU_NUEVA_CASA );
	],
	estaMisionCumplida [;
		return ( self.estado == 3 );
	],
	ponMisionCumplida [;
		self.estado = 3;
	],
	ponMisionEnCornualles [;
		self.estado = 2;
	],
	esInvisible [;
		return self.invisible;
	],
	hazInvisible [;
		self.invisible = true;
		ArrancarReloj( self, 4 );
	],
	tiempo_restante 0,
	tiempo_agotado [;
		self.invisible = false;
		"...es curioso ...notas un suave cosquilleo en las extremidades...";
	],
	getNumDia [;
		return self.numDia;
	],
	hacerPasarUnDia [ x;
		self.numDia++;

		! Avisar a todos los personajes
		objectloop ( x ofclass Personaje ) {
			x.esUnNuevoDia( self.numDia );
		}

		"^...un nuevo dÌa amanece...";
	],
    nombre 'Ulfius' 'yo' 'jugador' 'protagonista' 'prota',
    nombre_corto "Ulfius",
    fueMerlinEncontrado [;
    		return ( self.estado == 1 );
    ],
    ponMerlinEncontrado [;
    		self.estado = 1;
    		Conseguido( TAREA_ENCONTRAR_A_MERLIN );
    ],
    descripcion [;
    		self.cabecera();
    		if ( self.esInvisible() )
    			print " ...pero... °Un momento!^°No te ves a ti mismo!^
    			        °Eres invisible! ...vaya, aunque... øpor cu·nto tiempo?^";
    		else print ": las peleas contra los sajones te han hecho
    		            mella dej·ndote algunas cicatrices,
    		            sin embargo est·s ·gil y fuerte.^";

    		if ( uther.fueMisionEncomendada()
    		  && ~~jugador.estaEnEpilogo() )
    		{
    			print "Llevas ", self.getNumDia(), " dÌa";
    			if ( self.getNumDia() > 1 ) {
    				print "s";
    			}
    			print " de misiÛn.^";

	    		if ( self.estado == 0 ) {
	    			print "Debes concentrarte en tu misiÛn, encontrar a MerlÌn...^";
	    		}
	    		else
	    		if ( self.estado == 1
	    		  && localizacion ~= CARRUAJE )
	    		{
				print "°Debes volver al castillo de Uther PendragÛn!^";
	    		}
	    		else
	    		if ( self.estado == 2 ) {
				print "Debes guiar a Uther hasta los dormitorios de Lady Ingrain...^";
	    		}
	    		else
	    		if ( self.estado == 3 ) {
				print "°DebÈis salir del castillo y volver con MerlÌn!^";
	    		}
    		}

    		if ( ~~( self.esInvisible() ) )
    				<<Inv>>;
    		else		rtrue;
          ],
	conversacion [;
		self.decir( "Si empiezo a sentir la necesidad de hablar conmigo mismo, mal asunto..." );
	],
	reaccionar_antes [;
		ponerA:
			"Por favor, utiliza una de las siguientes formas:^
			 - ~pon (algo) en/sobre (otra cosa)~^
			 - ~echa (algo) en/sobre (otra cosa)~
			 ";
		atacar:
			if ( uno == self ) {
				"°Eso serÌa suicidio!";
			}
		escuchar:
			if ( localizacion == ROMPIENTE_OESTE
			  && confidente.estaLLegando() )
			{
				"Golpes de remos atenuados en el agua...";
			}
	]
has propio;

!---------------------------------------------------------------------
! Uther Pendragon, en la sala del trono inicialmente
!---------------------------------------------------------------------

class ServicioRey
class Personaje
with
	descripcion [;
		self.cabecera();
		print " es uno de los muchos infantes y caballeros al servicio del Rey.^";
	],
	antes [;
		atacar:
			banderafin = 1;

			print "^Atacas a ";
			self.cabecera( self.sinCambioLinea );
			print " salvajamente, sin provocaciÛn anterior...^^";

			"Sabes que has cometido un delito penado, sin posibilidad de perdÛn...";
	]
;

RespondeUnaVez reyImpaciente
private
	elementos
		" ...el Rey realiza un gesto de impaciencia con la mano..."
		"...el Rey comienza a parecer molesto..."
		" ...el Rey frunce el ceÒo, y crispa los labios en un gesto contrariado... "
;


ServicioRey Uther SALA_DEL_TRONO
		! Estado 0 - Va a contarte tu misiÛn
		! Estado 1 - esperando a que vuelvas con MerlÌn
		! Estado 2 - has encontrado a MerlÌn y espera que se lo presentes
		! Estado 3 - En el carruaje
		! Estado 4 - Te sigue por el castillo y no has hablado con Èl
		! Estado 5 - Te sigue por el castillo y has hablado con Èl
private
	vecesMolestado 0,
	numVecesDaPasta 0,
with
    articulo "al",
    nombre_corto "Rey Uther Pendragon",
    nombre 'Uther' 'rey',
	elNombre "Uther",
    antes [;
	atacar:
	    if ( self in SALA_DEL_TRONO ) {
    	        banderafin = 1;

    	        print "^Intentas atacar a ";
    	        self.cabecera( self.sinCambioLinea );
    	        print ", pero nunca llegas a estar cerca de conseguirlo, claro.^^";

    	        print "^Rufus y Rukus llegan desde la puerta...^";
    	        rufus.decir( "No me esperaba Èsto de ti, Ulfius... nunca lo hubiera pensado." );
    	        print "^Mientras tanto, Rukus sonrÌe...^";
    	        rukus.decir( "Vas a recibir tu merecido, muchacho..." );

    	        "Sabes que has cometido un delito penado, sin posibilidad de perdÛn...";
    	    }
	    else "No serÌa una buena idea.";
	hablar, examinar, responder, preguntar, orden: rfalse;
	default:
		if ( self in SALA_DEL_TRONO ) {
			"Los guardias impiden que siquiera te acerques al Rey...";
		}
    ],
    descripcion [;
    	    self.cabecera();
    		print ": el Rey Uther es de mediana edad, fuerte y ·gil.^";

    		if ( self.estado == 0 ) {
    			print "^El Rey espera, impaciente, a que te dignes a disponerte a hablar con Èl.";
    		}

    		rtrue;
    ],
    fueMisionEncomendada [;
    	return ( self.estado > 0 );
    ],
    haHabladoEnCastillo [;
        return ( self.estado < 5 );
    ],
    cambiarEstado [;
		if ( self.estado == 1
		  && Merlin.estaMerlinEnterado()
		  && jugador.fueMerlinEncontrado() )
		{
			self.estado = 2;
		}

		if ( self in CARRUAJE
		  && self.estado == 2 )
		{
			self.estado = 3;
		}

		if ( self in SUROESTE_DEL_CASTILLO
		  && self.estado == 3 )
		{
			self.estado = 4;
		}

		! Mover a uther con el propio jugador
		! Siempre que no estemos en el epilogo
		if ( self.estado >= 4
		  && localizacion ~= parent( self )
		  && ~~jugador.estaEnEpilogo() )
		{
			move self to localizacion;
			print "^...Uther te sigue...^";
		}
    ],
    reaccionar_antes [sigLoc;
        ir:
            sigLoc = patrullaNorte.siguienteLoc( localizacion, uno );

            if ( ( localizacion == COCINAS
                || localizacion == PASILLO_NOROESTE
                || localizacion == PASILLO_NORTE
                || localizacion == PASILLO_NORESTE
                || localizacion == PASILLO_SURESTE
                || localizacion == PASILLO_PRINCIPAL
                || localizacion == PASILLO_SUROESTE )
              && ( patrullaNorte in sigLoc
                || patrullaSur in sigLoc ) )
            {
                if ( uniformes notin jugador
                  || uniformes hasnt puesto )
                {
                    self.decir( "Ulfius, °creo que hay soldados ahÌ delante!" );
                    rtrue;
                }
            }
    ],
    conversacion [;
		print "Haces una pequeÒa reverencia...^";
		jugador.decir( "Mi seÒor..." );

		if ( jugador.esInvisible() ) {
			print (_El) self, " mira a derecha e izquierda...^";
			self.decir( "Ulfius, dejaos de juegos... °pardiez!" );
			rtrue;
		}

		if ( self.estado == 0 ) {
			self.decir( "Ulfius, te he mandado llamar por que un gran mal apena mi corazÛn.
			       Debo poseer a Lady Ingraine, aunque la vida y todo mi reino vaya en ello.
			       Como sabÈis, he puesto sitio a su castillo, en Cornualles.
			       Sin embargo, el sitio no parece efectivo.
			       Por eso, debo pediros, viejo amigo,
			       que vay·is en busca del ˙nico que puede ayudarme. Se trata del mago MerlÌn,
			       que vive en el bosque, al norte de aquÌ.
			       Tomad esta bolsa con dinero para pertrecharos y partid presto,
			       trayÈndolo ante mÌ." );

			print "^...uno de los cortesanos os alcanza una bolsa...^";
			move bolsa to jugador;
			self.estado = 1;
			self.vecesMolestado = 0;

			jugador.decir( "AsÌ lo harÈ mi seÒor." );

			"^Haces de nuevo una reverencia...^";

		}
		else
		if ( self.estado == 1 )
		{
			if ( bolsa in limbo ) {
				self.decir( "Decidme, bienquerido Ulfius, øquÈ os sucede?" );

				if ( ~~( BOLSA.fueRobada ) ) {
					print "^Inventas r·pidamente una excusa... øserÌan ladrones...?^";
					BOLSA.fueRobada = false;
				}

				jugador.decir( "Mi seÒor... debo reconocer, por deshonroso
				               que sea, que me han robado...,
				               y he perdido todo el dinero
				               que generosamente me disteis para llevar a buen
				               tÈrmino la misiÛn." );

				if ( self.numVecesDaPasta > 3 ) {
					banderafin = 1;
					self.decir( "Ulfius, me habÈis desilusionado demasiadas veces ya. No creo ni
					 que seais el hombre adecuado para la misiÛn, ni que teng·is realmente
					 interÈs en llevarla a buen tÈrmino. Me temo que sÛlo el calabozo os
					 har· daros cuenta de vuestro error."
					);
					print "^...el calabozo... no muy buen augurio espera, pues.^";
					rtrue;
				}

				self.decir( "Vaya, malditos bandidos... malditos sean,
				             como si no fuera suficiente con los sajones,
				             resulta que debemos temer tambiÈn a nuestros
				             compatriotas maleantes" );
				self.decir( "Tomad de nuevo una bolsa de dinero, e idos maÒana
				             y traedme a MerlÌn, como os dije." );

				self.numVecesDaPasta++;
				bolsa.resetMonedas();
				move bolsa to jugador;
				print "^un cortesano os alarga una bolsa...^";
				self.decir( "Ahora id a casa y descansad, es demasiado tarde ya." );

				print "Haces una reverencia, y te marchas.^";
				wait( "..." );
				print "^Caminas brevemente, hasta que llegas a tu casa";
				wait( "...^" );

				jugadorA( CASA_DE_ULFIUS, 2 );
				CASA_DE_ULFIUS.descansar();
				rtrue;
			}

			self.decir( "Ulfius, os ruego que no os demoreis m·s. Partid presto y traed a MerlÌn
			             ante mi." );

			self.vecesMolestado++;

			if ( self.vecesMolestado > 3 )
			{
				print "^^";
				print "El Rey parece comprender que no irÈis...^";
				self.decir( "Est· bien, Ulfius, encontrarÈ a otro que lo haga..." );
				self.decir( "Mientras tanto, os confino a presidio... indefinidamente..." );
				print "^^";

				print "...observas al Rey Uther mientras los guardias te llevan a las mazmorras.
				        Aunque en un principio est· incluso rojo de ira, una gran pena ensombrece
				        su mirada casi al momento.^";

				print (s_underline) "^En cuanto a ti, pues bueno... las mazmorras del castillo
				        nunca han tenido demasiada buena fama...^";
				banderafin = 1;
			}
			else {
				s_underline();
				print "^", (string) reyImpaciente.dev_msg(), "^";
				s_normal();
			}
		}
		else
		if ( self.estado == 2 )
		{
			Conseguido( TAREA_VOLVER_CON_MERLIN );
			self.decir( "Ulfius, °quÈ alegrÌa...!øHabÈis conseguido encontrar a MerlÌn...?øDÛnde est·...?" );
			move merlin to parent( self );
			merlin.decir( "°AquÌ estoy, mi Rey!" );
			print "^Tal y como prometiÛ, MerlÌn ha acudido, haciendo una
			       entrada muy dram·tica... en este momento realiza una
			       pronunciada reverencia.^";
			self.decir( "Ulfius, Merlin, acompaÒadme, debo hablaros en
			             privado..." );

			move merlin to PATIO_DE_ARMAS;
			move self to PATIO_DE_ARMAS;
			jugadorA( PATIO_DE_ARMAS, 2 );

			print "^MerlÌn y t˙ seguÌs al Rey al patio de armas.^
			       Mientras tanto, ha caÌdo la noche...^";

			merlin.decir( "Conozco el mal que os atribula, seÒor, y creo
			               que puedo ayudaros a conseguirlo esta misma noche.
			               SÛlo debÈis disponer un carruaje."
			);

			print "^El rey hace un gesto con la mano.^
				   El rictus de su cara revela ansiedad.
			       Un carruaje aparece dispuesto en poco tiempo...^";

			merlin.decir( "AcompaÒadnos, caballero, serÈis de mucha ayuda...");
			print "^Los tres os introducÌs en el carruaje, que os conducir·
			       al castillo donde reside Lady Ingrain.^";

			if ( POCION_PARA_INVISIBLE in jugador ) {
				print "^MerlÌn rebusca entre tus ropas, mientras sonrÌe irÛnicamente...^";
				merlin.decir( "Creo que ya no necesitarÈis Èsto..." );
				print "^MerlÌn os retira la pociÛn que habÌais conseguido de ~Mirlo~.^";
				move POCION_PARA_INVISIBLE to limbo;
			}

			if ( LLAVE in jugador ) {
				print "^MerlÌn busca algo en tus ropas...^";
				merlin.decir( "Disculpad, pero Èsto me pertenece..." );
				print "^MerlÌn os retira la llave de oro del laberinto.^";
				move LLAVE to limbo;
			}

			if ( LLAVE_PEQUENA in jugador ) {
				print "^MerlÌn busca algo en tus ropas, mientras te mira con el ceÒo fruncido...^";
				merlin.decir( "Disculpad, pero creo que Èsto me pertenece especialmente..." );
				print "^MerlÌn os retira la llave de su guardia.^";
				move LLAVE_PEQUENA to limbo;
			}

			move merlin to carruaje;
			move self to carruaje;

			jugadorA( CARRUAJE, 2 );
		}
		else
		if ( self.estado == 3 ) {
			print "^Uther parece dormitar tranquilamente...
					a pesar de su emociÛn inicial. No recuerdas haberte
					fijado en quÈ momento se quedÛ dormido. Los p·rpados
					ligeramente entornados le dan aspecto de estar despierto.
			       ^";
		}
		else
		if ( self.estado == 4 ) {
			jugador.decir( "øCu·l es el sentido de todo Èsto?" );
			self.decir( "øQuÈ querÈis decir?" );

			jugador.decir( "°No puedo creer que todo esto estÈ sucediendo
			                porque habÈis tenido la apetencia repentina
			                de acostaros con una mujer!"
			);

			self.decir( "Ulfius, °no os consiento que me hablÈis asÌ!" );
			jugador.decir( "øTodas estas vidas en peligro,
			                todo este esfuerzo, por un deseo carnal?"
			);

			self.decir( "No podÈis entenderlo..." );
			print "^Uther parece querer aclarar sus ideas, pero su rostro
			       demuestra tanta confusiÛn como anteriormente";
			wait( "...^" );
			jugador.decir( "Y ese MerlÌn... °no me fÌo de Èl! ...con
			                sus frascos de pociÛn y..." );

			self.decir( "°Basta Ulfius...! No es la primera vez que
			            MerlÌn me ayuda..." );
			self.decir( "Gracias a Èl, en el futuro serÈ recordado como el
			             Rey unificador de todo Locres, y..." );

			jugador.decir( "...o el Rey m·s fornicador de todo Locres" );

			print "^El rostro de Uther se pone rojo de ira.^";
			wait( "...^" );

			print "A continuaciÛn, Uther parece relajarse. Ya m·s calmado,
			       dice";
			wait( "...^" );

			self.decir( "Basta, Ulfius, Èsto no nos lleva a ninguna parte." );

			jugador.decir( "A mi sÌ, Uther. Cuando todo Èsto acabe, me retirarÈ
			                de vuestro servicio."
			);

			print "^Uther se queda un momento callado, meditando vuestra decisiÛn";
			wait( "...^" );
			print "El rostro de Uther se ensombrece un momento";
			wait( "...^" );
			self.decir( "Y asÌ ser· si lo dese·is entonces, Ulfius.
			       Ahora continuemos y acabemos de una vez."
			);
			self.estado++;
		}
		else
		if ( self.estado == 5 ) {
		    if ( parent( self ) ~= parent( merlin ) ) {
		        self.decir( "Es suficiente, Ulfius, tratemos de terminar la
			             misiÛn, ya hablaremos luego si fuere menester." );
		    }
		    else {
		        self.decir( "Preguntad a MerlÌn quÈ haremos ahora." );
		        print "^°Por Dios...!øEs que no se escucha a sÌ mismo...?^";
		    }
		}
	]
;

