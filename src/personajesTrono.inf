! --------------------------------------------------------------------
! Mirlo, el anciano de la cabaÒa
! --------------------------------------------------------------------
Vendedor Mirlo CABANA
! Estado 0 no ha hablado contigo
! Estado 1 ya ha hablado contigo
with
	elNombre "anciano",
	pasaANombrePropio [;
		self.elNombre = "Mirlo";
		self.Personaje::pasaANombrePropio();
	],
	nombre_corto "anciano",
	nombre 'mirlo' 'anciano',
	adjetivos 'achacoso' 'viejo' 'invalido',
	descripcion [;
		self.cabecera();
		" es de apariencia achacosa, pequeÒo y encorvado sobre su bastÛn.
		Se sienta en su mecedora, y no parece que pudiera levantarse de allÌ.";
	],
	cambiarEstado [;
		if ( jugador.fueMerlinEncontrado() ) {
			pararDaemon( self );
			move Merlin to parent( self );
			move self to limbo;
		}
	],
	objetoAVender Nothing,
	precio 4,
	conversacion [;

		if ( jugador.esInvisible() ) {
			print (_El) self, " te mira directamente cuando te diriges a Èl. Est· claro que no
			      se deja engaÒar por sus propias artimaÒas...^";
		}

		if ( self.estado == 1 ) {
		  if ( POCION_PARA_INVISIBLE notin limbo ) {
			jugador.decir( "Mirlo..." );
			self.decir( "Marchaos, marchaos ya... Dejadme descansar..." );
			rtrue;
		  } else {
		  	self.objetoAVender = POCION_PARA_INVISIBLE;
		  	self.precio = 4;
		  	print "^...el anciano abre pesadamente los ojos...^
		  	       Notas un brillo en su mirada... parece adivinar lo que
		  	       quieres...^";
		  	self.decir( "Tengo m·s pociÛn, pero me temo
		  	             que tendrÈ que vendÈrosla por 4 monedas..."
		  	);
		  	rtrue;
		  }
		}

		jugador.decir( "Buen dÌa, anciano,
					  tal vez puedas ayudarme en mi b˙squeda.
					  Soy Sir Ulfius de la Corte del Rey Uther PendragÛn. øVos quien sois?"
		);

		self.decir( "Hola, Sir Ulfius, mi nombre es Mirlo, os ayudarÈ si est· dentro de mis
		 			posibilidades, las cuales, como veis, son pocas. øQuÈ precisais?"
		);

		self.pasaANombrePropio();

		jugador.decir( "He sido designado por el Rey Uther para Buscar a MerlÌn.
				      Seg˙n la informaciÛn que manejo, ese hombre vive en este bosque."
		);

		self.decir( "øMerlÌn, eh...? Mmm... y para quÈ querrÌais verle." );
		print "^...sientes una punzada de extraÒeza...^";
		jugador.decir( "Eso no es de tu incumbencia, anciano." );

		self.decir( "No, claro, claro que no, je... je..." );
		print "^El anciano intenta reirse, pero su risa termina en unos estertores terribles... al cabo de un
		       rato, contin˙a...^";

		self.decir( "No puedo ayudarle joven caballero, no sÈ dÛnde est· MerlÌn,
		             aunque, que yo sepa, su residencia no es Èsta, sino las montaÒas al norte."
		);

		self.decir( "Pero permitidme haceros un presente... nadie puede atravesar este bosque y pretender
		             no correr ning˙n riesgo..."
		);

		print "^el anciano se levanta trabajosamente y se encamina a uno de los estantes, de donde toma
		       un pequeÒo frasco que os alarga.^";

		self.decir( "Aceptad esto... °nunca se sabe!" );

		move POCION_PARA_INVISIBLE to jugador;

		print "^Ahora en la mirada del anciano parece destellar la mirada de un bromista, de gran viveza.
			    Pero esa mirada se desvanece y sÛlo queda la cansada mirada del anciano...
			    hasta el punto de preguntarte si lo has visto realmente o ha sido tu imaginaciÛn...^";

		jugador.decir( "Gracias, anciano." );

		print "^el anciano vuelve a sentarse y parece sumirse en un trabajoso sopor....^";
		self.decir( "Ahora marchaos, caballero, y buena suerte en vuestra misiÛn..." );

		self.estado++;
	]
;

! --------------------------------------------------------------------
! MerlÌn, el mago
! --------------------------------------------------------------------
Personaje Merlin limbo
	! estado = 0 en cabaÒa no hablo contigo
	! estado = 1 ya hablÛ contigo sobre la misiÛn
	! estado = 2 Carruaje
	! estado = 3 Ya hablÛ contigo en el carruaje
	! estado = 4 Al suroeste del castillo
	! estado = 5 Fin de misiÛn
with
	elNombre "anciano",
	pasaANombrePropio [;
		self.elNombre = "MerlÌn";
		self.Personaje::pasaANombrePropio();
	],
	estaMerlinEnterado [;
		return ( self.estado >= 1 );
	],
	nombre_corto "anciano",
	nombre 'merlin' 'anciano' 'mago' 'druida',
	descripcion [;
		self.cabecera();
		print " es el famoso mago. Lleva una t˙nica, ajustada mediante un cinto, una sandalias,
			    y un bastÛn por toda vestimenta.
			    Su mirada denota inteligencia, y cuando te mira, lo hace entre divertido y curioso.^";
		if ( self in CABANA ) {
			self.cabecera();
			print " est· sentado en su mecedora.^";
		}
	],
	cambiarEstado [;
		if ( self in CARRUAJE
		  && self.estado == 1 )
		{
			self.estado = 2;
		}

		if ( self in SUROESTE_DEL_CASTILLO
		  && ( self.estado == 2 or 3 ) )
		{
			self.estado = 4;
		}

		if ( self.estado == 4
		  && localizacion == SUROESTE_DEL_CASTILLO
		  && jugador.estaMisionCumplida() )
		{
			self.estado = 5;
		}
	],
	ponAMerlinEnterado_debug [;
		! SÛlo para depurar
		self.estado = 1;
	],
	conversacion [;

		if ( jugador.esInvisible() ) {
			print (_El) self, " te mira directamente cuando te diriges a Èl... est· claro que
			      se deja engaÒar por sus propia artimaÒa...^";
		}

		if ( self.estado == 0 )
		{
			self.estado++;
			jugador.decir( "Hola, soy..." );

			self.cabecera();
			print " alza la mano, invit·ndoos a dejar de hablar.^";

			if ( self hasnt propio ) {
				self.pasaANombrePropio();
			}

			self.decir( "SÈ quien sois, ~hablamos~ hace poco, ølo record·is?" );
			print "^Te sientes incÛmodo y un tanto molesto ante este personaje,
			       que parece pretender saberlo todo.^";

			jugador.decir( "El rey Uther le espera en el castillo..." );
			self.decir( "Esta bien, comunÌcale que allÌ estarÈ" );

			jugador.decir( "...a la mayor brevedad." );
			self.decir( "Partid, Ulfus, estarÈ allÌ." );

			if ( LLAVE_PEQUENA notin felpudo
			  || PUERTA_EXPLANADA_DE_ROCA has abierta )
			{
				print "^La mirada de MerlÌn parece crisparse un momento...^";
				self.decir( "Por cierto..." );
				self.decir( "Os pedÌ que dejar·is la puerta cerrada y la llave bajo
				             el felpudo y no lo habÈis hecho."
				);

				self.decir( "Es decepcionante que todo un caballero del Rey no pueda
				             cumplir encargo tan sencillo..."
				);

				jugador.decir( "Lo siento, no creÌ que fuese tan importante..." );

				print "^MerlÌn gruÒe algo y mira hacia otro sitio.^";
			}
		}
		else
		if ( self.estado == 1 ) {
			jugador.decir( "øPor quÈ todo Èsto...?øPor quÈ...?");
			self.decir( "Todo a su tiempo, mi buen Ulfius." );
			print "^Hace un gesto de impaciencia con la mano...^";
			self.decir( "Partid, Ulfus, y creedme, estarÈ allÌ." );
		}
		else
		if ( self.estado == 2 ) {
			print "^El carruaje lanza ocasionalmente pequeÒos crujidos y gemidos...^";
			jugador.decir( "ø Me dirÈis ahora cu·l es el sentido de todo Èsto?"
			);

			self.decir( "Mi buen Ulfius, me temo que las implicaciones de los
			             acontecimientos que estamos viviendo nos sobrepasan
			             incluso a ambos..."
			);

			jugador.decir( "Necesito saber que mi vida ha sido puesto en juego
			                por algo m·s que un simple deseo carnal."
			);

			self.decir( "De eso podÈis estar seguro, Ulfius. El v·stago del
			             Rey ser· el prÛximo Rey de Locres, conocido y
			             querido sin igual, m·s que cualquier otro Rey." );

			jugador.decir( "Pero... øSois vos el que...?" );

			self.decir( "Descansad ahora, Ulfius, todavÌa queda mucho por hacer..." );
			self.estado++;
		}
		else
		if ( self.estado == 3 ) {
			jugador.decir( "Pero..." );
			self.decir( "Confiad en mÌ, Ulfius, y descansad ahora." );
		}
		else
		if ( self.estado == 4 ) {
			jugador.decir( "øPodÈis decirme exactamente que he de hacer?" );
			self.decir( "Entrar en el castillo, guiar al Rey al dormitorio de
			             Lady Ingrain, aguardar hasta que salga y traerlo
			             de vuelta hasta aquÌ." );
		}
		else
		if ( self.estado == 5 ) {
			Conseguido( TAREA_TERMINAR_AVENTURA );

			jugador.decir( "Est· bien. Est· hecho." );
			self.decir( "Enhorabuena Ulfius, ahora volvamos y..." );

			jugador.decir( "NO." );
			print "^MerlÌn mira al Rey sorprendido, el Rey le devuelve la mirada.^";
			wait( "...^" );
			print "^El rostro del Rey es mucho m·s grave";
			wait( "...^" );
			self.decir( "øNo?" );

			jugador.decir( "No, para mi todo Èsto ha acabado.");
			jugador.decir( "Incluyendo especialmente el servicio al Rey Uther.");
			jugador.decir( "Me voy." );
			print "^Te das la vuelta para marcharte...^";

			uther.decir( "Sois un caballero. SÛlo sabÈis guerrear.
			              øDe quÈ vivirÈis?"
			);

			jugador.decir( "He aprendido a vivir mi vida guerreando, ahora
			             mismo dudo de por quÈ o para quÈ.
			 			 A partir de ahora aprenderÈ a vivirla en paz." );

			uther.decir( "No puedo creerlo. °Un caballero del Rey!
			              øOs harÈis granjero, os casarÈis y tendrÈis hijos?"
			);

			jugador.decir( "Algo asÌ. No veo quÈ mal puede haber." );

			print "^Por un momento, crees ver cruzar un atisbo de aprobaciÛn
			        por el rostro de MerlÌn.^";
			wait( "...^" );
			print "^El Rey interviene de nuevo...^";
			uther.decir( "DespuÈs de vuestros abnegados servicios, no puedo
			              negaros nada, Ulfius, ni siquiera eso." );

			print "^...asientes.^";
			jugador.decir( "AdiÛs." );
			self.decir( "Volveremos a vernos, Ulfius" );

			print "^Aprietas los labios";
			wait( "...^" );
			jugador.decir( "Manteneos alejado de mi." );

			wait( "^...^" );
			print "Pasan los meses";
			wait( "^...^" );
			self.estado++;

			epilogo1();
		}
		else
		if( self.estado == 6 ) {
			jugador.decir( "°MerlÌn...!øQuÈ hacÈis aquÌ?" );

			merlin.decir( "Contened vuestra rabia, mi buen Ulfius. No he venido
						   aquÌ a encargaros ninguna misiÛn ni perturbar demasiado
						   vuestro retiro."
			);

			jugador.decir( "°Os dije que os alejarais de mi!" );

			merlin.decir( "Lo sÈ, pero tranquilizaos, pronto me irÈ y seguramente
					   no volverÈis a verme. Quiz·s una vez m·s, como mucho."
			);

			merlin.decir( "Lamento que hay·is equivocado mi papel en toda esta historia..." );
			merlin.decir( "Solo vengo a dejaros este bebÈ a vuestro cuidado." );

			jugador.decir( "ø°QuÈ...!?øDe quiÈn es?" );
			merlin.decir( "De Uther e Ingrain" );

			print "^Tu rostro se endurece al recordar todo aquello de nuevo... como
			   si las compuertas de una gran presa se abrieran del todo, recuerdas
			   aquellos dÌas, aquella noche que guiaste a Uther y el profundo
			 resquebrajamiento de todos los valores que desde niÒo te habÌan
			   inculcado.^";

			jugador.decir( "øPor quÈ yo?");
			merlin.decir( "Por que quiero para Èl una educaciÛn de caballero, pero
					   lejos de las intrigas de la corte. Quiero para Èl
					   una educaciÛn en los valores de respeto por la vida que
					   vos parecÈis poseer. Porque quiero que se convierta
					   en el m·s grandioso Rey de Locres que haya existido.
					   Por favor, aceptad."
			 );

			print "^Tomas al niÒo en tus brazos. MerlÌn ya se encamina hacia
			   la puerta para irse.^";
			wait( "...^" );

			jugador.decir( "°Esperad...!øCÛmo se llama?");
			print "^MerlÌn esboza una gran sonrisa.^";
			merlin.decir( "Arturo, claro est·." );

			print "^MerlÌn finalmente desaparece.
				Y t˙ te quedas finalmente con el niÒo.^";
			wait( "...^" );

			epilogo3();
		}
	]
;

!---------------------------------------------------------------------
! El caballero negro
!---------------------------------------------------------------------
respondeUnaVez amenazasCN
private
	elementos
		"°No podÈis pasar!, soy el guardi·n de este camino."
		"°øNo me habÈis oÌdo...!? Enfrentaos a mi en singular duelo si querÈis continuar."
		"Os lo advierto por ˙ltima vez: volved por donde habÈis venido.
		Para pasar, luchad o... morid."
		"°Est· bien caballero...! Sois o bien est˙pido o bien duro de de oÌdo,
		me da igual. Es vuestra ˙ltima oportunidad."
		"°Est· bien...! TendrÈ que mataros."
with
	haz_accion_final [;
		print "^", (el) caballeroNegro, " se prepara para luchar con vos...
				^mal pertrechado y armado, no tard·is en caer...^"
		;
		banderafin = 1;
	]
;

respondeUnaVez pensamientosSobreCaballeroNegro
private
	elementos
		"^°Dios mÌo...!øEn Èsto se ha convertido la caballerÌa...? Lecciones
		 como el honor, la responsabilidad o la justicia parecen meras
		 caricaturas cuando observas a este caballero defender un in˙til trozo
		 de tierra."
		"A˙n en igualdad de condiciones (no llevas tus armas), no te
	     enfrentarÌas a un fantoche como Èste...^°Pardiez!, te hace avergonzarte
	     de ser caballero."
	    "Espero que nadie me confundiera con alguien como este pretendido caballero, en
	     el pasado."
	    "øVes tu vida reflejada en este fantoche de caballero? øHa tenido sentido?
	     ~øQuiÈn soy y quÈ quiero hacer?~, te preguntas...
	     no quiero ser alguien como Èste ~caballero~."
;

Personaje caballeroNegro POZO
! Estado 0 - Normal
! Estado 1 - Alelado por la peonza
private
    objetivo obj_n,
with
	elNombre "caballero negro",
    articulo "al",
    nombre_corto "caballero negro",
    nombre 'caballero' 'negro',
    ponVieneDeLoc [ loc;
    		if ( loc == COLINA ) {
    			self.objetivo = obj_s;
    		}
    		else
    		if ( loc == CAMINO_NOROESTE ) {
    			self.objetivo = obj_n;
    		}
    		else "^^ERROR: El caballero negro no sabe quÈ salida ~tapar~.^^";
    ],
    descripcion [;
    		print (_El) self, " viste una elegante armadura, completamente negra,
    		       sin brillos, que no puedes reconocer de ning˙n monarca que
    		       conozcas.^";
    		;

    		if ( self.estado == 1 ) {
    			print "El otrora orgulloso y belicoso caballero est· sentado en
    			       el juego, jugando con su peonza...^";
    		}
    		else
    		if ( self.estado == 0 ) {
    			if ( random( 0, 1, 2, 3, 4, 5 ) > 3 ) {
		    		print "Repentinamente, con gesto amenazador,
		    		       posa su mano en el puÒo de su espada y exclama...^"
		    		;

		    		self.decir( "°Dejad de mirarme asÌ!" );
    			}
    		}

    		rtrue;
    ],
    vida [;
    		dar, mostrar:
    			if ( uno == peonza ) {
    				move peonza to self;
    				self.decir( "...una... peonza...^
    				      cuanto me recuerda Èsto mi niÒez..."
    				);

				print " ...lo cierto es que no te esperabas lo que est·s
				       viendo...^°el caballero se ha puesto a jugar con la
				       peonza!^";
				rtrue;
    			}
    ],
    cambiarEstado [;
    		if ( peonza in self ) {
    			self.estado = 1;
    			Conseguido( TAREA_CABALLERO_NEGRO );
    		}
    ],
	conversacion [;
		jugador.decir( "Caballero, estoy en misiÛn encargada por el Rey Uther
		            PendragÛn, debÈis dejarme pasar, y..."
		);

		if ( jugador.esInvisible() ) {
			print (_El) self, " mira a derecha e izquierda...^";
			self.decir( "°MaldiciÛn...!øQuÈ brujerÌa es Èsta?" );
			print (_El) self, " da unos cuantos mandobles a diestro y siniestro...^";
			rtrue;
		}

		if ( self.estado == 0 ) {
			self.decir( "Si dese·is pasar, caballero, deberÈis luchar conmigo." );

			print (_El) self, " es desde luego parco en palabras... y amenazador.^";

			print (string) pensamientosSobreCaballeroNegro.dev_msg(), "^";

			if ( mirlo has propio ) {
				! Si mirlo ya no es "el anciano", has hablado con Èl.
			     print "^Recuerdas las palabras del anciano de la cabaÒa :
						~Nadie puede aventurarse a atravesar este bosque pensando
						que no correr· peligro alguno~^^."
			     ;
			}
		}
		else
		if ( self.estado == 1 ) {
			print (_El) self, " desvÌa brevemente la mirada de la peonza y...";
			self.decir( "Id a donde quer·is, y no me molestÈis..." );

			print (_El) self, " sigue siendo, desde luego, parco en palabras...
					^y a˙n jugando a la peonza aparenta ser amenazador...^"
			;
		}

		rtrue;
	],
	antes [;
		atacar:
			banderafin = 1;

			! Aprestar al jugador para el combate...
			print "^Te aprestas para el combate...^";
			if ( ARMADURA_DE_ACERO in jugador
			  && ARMADURA_DE_ACERO hasnt puesto )
			{
				print "...te colocas la armadura de acero...^";
			}

			if ( ARMADURA_DE_CUERO in jugador
			  && ARMADURA_DE_ACERO notin jugador )
			{
				print "...te colocas la armadura de cuero...^";
			}


			! Entablar combate (nunca gana, no nos engaÒemos)...
			if ( ARMADURA_DE_ACERO in jugador ) {
				print "^Gracias a la armadura de acero, los primeros golpes m·s mortÌferos
				       de tu rival se estrellan sin remedio en el frÌo metal... sin
				       embargo, es un combate desigual...^";
			}
			else
			if ( ARMADURA_DE_CUERO in jugador
			  && ARMADURA_DE_ACERO notin jugador )
			{
				print "^Poco puede hacer la ligera armadura de cuero contra la afilada
				       espada de combate de tu rival, quien disfruta s·dicamente con
				       el desigual combate...^";
			}
			else
			if ( ESPADA in jugador )
					print "^Entablas desigual combate con la sola ayuda de tu espada...^";
			else 	print "^Entablas una lucha desigual... °con tus manos desnudas...!^";

			print "^Me temo que no eres rival para ", (el) self, ".^";
			"Mejor pertrechado que t˙, descansado, y armado, acaba contigo
			en un santiamÈn.^";
	],
	! Hay que "taponar" que el jugador pueda continuar
	reaccionar_antes [;
		ir:
			if ( self.estado == 0 )
			{
			  if ( uno == self.objetivo ) {
				! Si el jugador trata de ir hacia "delante"
				if ( jugador.esInvisible() ) {
					print "^^El caballero negro lanza tajos a diestro
					       y siniestro...^";
					self.decir(
						"°MaldiciÛn! °No huy·is...!°SÈ que est·is ahÌ...!
						 °Haceros ver y enfrentaros a mi en justa lid...!"
					);
					print "^^Est·s claro que para ", (el) self, " el hecho
					       de ir casi desarmado en comparaciÛn con Èl no
					       es algo a tener en cuenta.^";
				}
				else {
					print (_El) self, " cruza su espada delante de vos...^";
					self.decir( amenazasCN.dev_msg() );
					rtrue;
				}
			  }
			}

			rfalse;
	]
;

! --------------------------------------------------------------------
! El dueÒo de la taberna
! --------------------------------------------------------------------
Vendedor cantinero INTERIOR_DE_LA_TABERNA
	! estado 0 - No has hablado con Èl
	! estado 1 - Ya has hablado con Èl - te ofrece pan
	! estado 2 - le preguntas por MerlÌn
private
	merlinComentado false,
with
	elNombre "cantinero",
	pasaANombrePropio [;
		self.elNombre = "Fred";
		self.Personaje::pasaANombrePropio();
	],
	fueMerlinComentado [;
		return self.merlinComentado;
	],
	nombre_corto "cantinero",
	nombre 'cantinero' 'camarero' 'vendedor' 'barman' 'dueno' 'fred' 'hombre'
	       'tabernero',
	objetoAVender bolla,
	precio 6,
	conversacion [;
		if ( self has propio )
				jugador.decir( "Fred..." );
		else	jugador.decir( "Cantinero..." );

		if ( jugador.esInvisible() ) {
			jugador.decir( "Buen hombre..." );
			print (_El) self, " permanece impasible...^";
			self.decir( "Mi seÒor, prefiero no hablaros cuando no puedo veros." );
			rtrue;
		}

		if ( self.estado == 0 )
		{
			jugador.decir( "Me llamo Ulfius, de la corte del
			                Rey Uther PendragÛn."
			);

			self.decir( "Hola, caballero. Mi nombre es Fred, si dese·is algo." );
			print (_El) self, " no parece impresionado. Sigue con sus quehaceres.";

			self.pasaANombrePropio();
			self.estado++;
		}
		else
		if ( self.estado == 1 )
		{
			print (el) self, " mira brevemente hacia vos...^";

			if ( self.objetoAVender ~= Nothing ) {
				self.decir( "Tengo una bolla de pan a la venta, si la dese·is.
							ser·n 6 piezas de oro."
				);
			}
			self.decir( "Me temo que no dispongo de nada m·s" );
			self.estado++;
		}
		else
		if ( self.estado == 2 )
		{
			self.merlinComentado = true;

			jugador.decir( "øHa visto alguna vez a MerlÌn, por aquÌ?" );
			self.decir( "øMerlÌn..? No, no suele andar por aquÌ." );

			jugador.decir( "El Rey me manda buscarle." );
			self.decir( "MerlÌn... siempre est· rondando algunos lugares,
						pero solo lo encontrar·s si Èl
						quiere ser encontrado"
			);

			print "...comenta mientras repasa algunas copas ubic·ndolas
				   ordenadamente sobre el mostrador...^";

			self.estado--;
		}
	],
	descripcion [;
		self.cabecera();
		" es un hombre gordo y alto, de poca conversaciÛn.";
	]
has;

! --------------------------------------------------------------------
! el caballero de la taberna
! --------------------------------------------------------------------
Vendedor tristan INTERIOR_DE_LA_TABERNA
	! estado 0 - no has hablado con Èl
	! estado 1 - ha puesto el mapa sobre el mostrador
	! estado 2 - Te ha dicho que quiere pasta por el mapa y espera por ella
	! estado 3 - Le has pagado, y desaparece
with
	elNombre "caballero",
	pasaANombrePropio [;
		self.elNombre = "Trist·n";
		self.Personaje::pasaANombrePropio();
	],
	nombre_corto "caballero",
	nombre 'caballero' 'tristan' 'borracho' 'borrachin' 'joven' 'hombre',
	precio 8,
	objetoAVender mapa,
	estaOfreciendoMapa [;
		return ( self.estado == 2 );
	],
	fueMapaVendido [;
		return ( self.estado == 3 );
	],
	cambiarEstado [;
		if ( self.objetoAVender == Nothing
		  && self notin limbo )
		{
			move self to limbo;
			self.decir( "El mapa es vuestro, seÒor... aunque no sÈ para quÈ
						podrÌas quererlo. En cualquier caso, mucha suerte."
			);
			self.estado = 3;
			"...Trist·n se yergue como puede, y se marcha.
			Secretamente, esperas que encuentre
			la paz que tan desesperadamente necesita en otros menesteres.";
		}
	],
	conversacion [;

		if ( jugador.esInvisible() ) {
			jugador.decir( "Joven..." );
			print (_El) self, " mira extraÒado a derecha e izquierda...^";
			self.decir( "°Oh, Dios mÌo...! Ahora ya tengo alucinaciones...^" );
			print (_El) self, " bebe de nuevo...^";
			rtrue;
		}

		if ( self.estado == 0 )
		{
			jugador.decir( "Hola, joven" );
			self.decir( "...ø!... Hola, caballero..." );

			print "^ ...su voz suena achispada y su mirada no parece poder
			       enfocarte.^";

			self.estado++;
		}
		else
		if ( self.estado == 1 ) {
			jugador.decir( "øCÛmo habÈis acabado aquÌ?" );
			print "...interrogas al borrachÌn, buscando conversaciÛn...^";
			self.decir( "El rey Uther me encomendÛ una misiÛn" );
			print "...el caballero hace una pausa, con l·grimas en los ojos...^
			       ~øes posible?~ - piensas -...^";
			self.decir( "Pero he fracasado. No sÈ ni hacia dÛnde
						ir ahora. øQuÈ harÈ con lo que me queda de vida?."
			);
			self.decir( "No puedo presentarme asÌ ante el Rey..." );
			print " ...un caballero que no conoces, de la corte del Rey...
			        °y como a ti, le encargaron una misiÛn...!^
			        ~øSer· la misma?~,
			        ~øCu·nto esfuerzo habr· vertido ya el Rey en esta misiÛn?~ - Te preguntas.^";
			jugador.decir( "øQuiÈn sois?" );
			self.decir( "Soy... era... Trist·n, caballero de la corte del Rey Uther" );
			self.pasaANombrePropio();

			print "~°Trist·n!~ -recuerdas- ~°...uno de los m·s jÛvenes
			       y prometedores caballeros!~^
			       ...no puedes aguantar la intriga...^";
			jugador.decir( "øCu·l era esa misiÛn?" );
			print "El borracho parece recuperar la compostura
			       por primera vez en toda la
			       conversaciÛn.^
			       Te mira fijamente mientras se incorpora levemente";
			wait( "...^" );
			self.decir( "Encontrar al mago MerlÌn." );
			print "...una punzada de agonÌa atraviesa tu estÛmago...^";
			jugador.decir( " øY... le encontrasteis? " );
			print "Casi adivinas la respuesta antes de que hable...^";
			self.decir( "°Si!°Y me ha convertido en lo que soy ahora!" );
			print "...responde, tratando de parece gracioso
			       e irÛnico a la vez, si bien su
			       respuesta parece m·s bien histÈrica.";
			wait( "^..." );
			print "luego repara, con un poco m·s de seriedad:^";
			self.decir( "No hay manera de encontrarlo." );
			print "...la frustraciÛn es palpable en su voz.^";
			self.decir( "Un caballero amigo me entregÛ esto,
					    dijo que me facilitarÌa la b˙squeda,
					    temo que se equivocÛ o me jugÛ una broma..." );
			print "...arroja un pergamino sobre el mostrador.^";

			move mapa to parent( self );
			self.estado++;

			self.decir( "Se trata de un laberinto que hay que atravesar
			             antes de poder llegar a la guardia de MerlÌn."
			);

			jugador.decir( "øA quÈ distancia se encuentra este laberinto?" );
			print "...Trist·n solloza moment·neamente y comienza a explicar...^";
			self.decir( "Cerca. Tomad el camino que lleva hacia el norte,
			            os guiar· por entre las montaÒas.
			            Dicen que al final del camino de la montaÒa
			            se observa el dichoso laberinto."
			);
			print "...Trist·n irrumpe en una risa histÈrica";
			wait( "...^" );
			self.decir( "Pero no es posible... ølo entendÈis?
			             Nunca llegarÈis tan lejos... nunca
			             pasarÈis el abismo."
			);
			print "~Trist·n yace reducido a una pulpa gimoteante, sÛlo
			       por intentar satisfacer los caprichos de un Rey. No es
			       justo~. - Piensas.^";
		}
		else
		if ( self.estado == 2 ) {
			jugador.decir( "Me interesa ese mapa..." );
			self.decir( "Ya sabes... este mapa es tuyo...
						si me d·s algo a cambio.
						Dinero para mÌ est· bien: pongamos 8 monedas.
						Debo buscarme una nueva vida, y...
						no puedo...
						no quiero volver a ser caballero del Rey.
						Quiz·s me vaya... sÌ, eso es, lejos."
			);
			jugador.decir( "No parece mala idea, amigo mÌo." );

		}
	],
	antes [;
		comprar:
			if ( self.estado ~= 2 ) {
				"No parece que ", (el) self, " quiera venderte nada.";
			}
	],
	descripcion [;
		self.cabecera();
		" est· tumbado sobre la barra. Me temo que est· borracho perdido,
		aunque su atuendo no se corresponde con el tÌpico borracho.";
	]
has;


!---------------------------------------------------------------------
! El caballero perdido en el laberinto
!---------------------------------------------------------------------

RespondeUnaVez pensamientosSobreGalahad
private
    elementos
        "~Galahad est· destrozado~ - piensas -, ~otro gran caballero
         vencido en esta grotesca misiÛn~."
        "~øMerece la pena realizar una misiÛn como Èsta?~ - Te preguntas."
        "~Empiezo a estar harto de violencia y sufrimiento~
         - Te descubres a ti mismo pensando..."
;

Personaje Galahad CALLEJON_2
	! Estado 0 - desesperado en el laberinto
	! Estado 1 - Le das el mapa
private
	mePuedoIr false,
	descubierto false,
with
	elNombre "caballero",
	pasaANombrePropio [;
		self.elNombre = "Galahad";
		self.Personaje::pasaANombrePropio();
	],
	estaDescubierto [;
		return self.descubierto;
	],
	ponEstaDescubierto [;
		self.descubierto = true;
		self.pasaANombrePropio();
	],
    nombre_corto "caballero",
    nombre 'caballero' 'galahad',
    descripcion [;
	    if ( ~~self.estaDescubierto() ) {
	   	print "°...un momento!°...es Galahad...!^";
	    }

    	    self.ponEstaDescubierto();

    	    self.cabecera();
    	    print " yace en el suelo, recostado contra el muro,
    	            con una desconsoladoramente desorientada mirada perdida.^"
    	    ;

    	    self.cabecera();
    		print ": es extraordinariamente joven, pese a lo cu·l ha conseguido llega a caballero antes
    		         que nadie. Su arrojo est·n fuera de toda duda, si bien ahora mismo est· claro que le
    		         invade la desesperaciÛn.^^";

    	    print (string) pensamientosSobreGalahad.dev_msg(), "^";

    		rtrue;
    ],
    cambiarEstado [;
    		if ( mapa in self
    		  && self.estado == 0 )
    		{
    			self.estado = 1;
    			Conseguido( TAREA_GALAHAD );
    		}

    		if ( self.mePuedoIr
    		  && self notin localizacion
    		  && self notin limbo )
    		{
    			self.mePuedoIr = false;
    			move self to limbo;
    		}
    ],
	conversacion [;
    		if ( ~~self.estaDescubierto() ) {
    	   		print "°...un momento! ... °es Galahad...!^";
    	    		self.ponEstaDescubierto();
    	   	}

		if ( jugador.esInvisible() ) {
			jugador.decir( "Galahad..." );
			print (_El) self, " mira extraÒado a derecha e izquierda...^";
			self.decir( "°Oh, Dios mÌo...! Voy a morir, es ya seguro...^" );
			rtrue;
		}

		if ( self.estado == 0 ) {
			print "^El caballero musita entrecortadamente...^";
			self.decir( "...no puedo continuar, Ulfius, no puedo,
			             es demasiado grande, demasiado... querrÌa
			             salir de aquÌ, pero... es demasiado,
			             demasiado..." );
		}
		else
		if ( self.estado == 1 ) {
			print "^El caballero parece ahora tranquilo y relajado, con el
			       mapa apretado contra su pecho.^";
			self.decir( "En cuanto me recupere un poco irÈ, Ulfius, amigo
			             mÌo, no es entreteng·is m·s por mi."
			);
		}

		print "^", (string) pensamientosSobreGalahad.dev_msg(), "^";
	],
	tiempo_restante 0,
	tiempo_agotado [;
		self.mePuedoIr = true;

		if ( localizacion == parent( self ) ) {
			"Galahad parece estar realmente mucho mejor...";
		}
	],
	vida [;
		dar, mostrar:
			if ( uno == mapa ) {
		    		if ( ~~self.estaDescubierto() ) {
		    	   		print "°Un momento...!°Es Galahad...!^";
		    	    		self.ponEstaDescubierto();
		    	   	}

				move mapa to self;
				print "Galahad toma el mapa con incredulidad...^
				       Parece recuperar la cordura en ese mismo momento.";
				self.decir( "°El mapa de este maldito laberinto... gracias, Ulfius!" );
				jugador.decir( "Espero que ahora pod·is salir de aquÌ por vuestro
				                propio pie, amigo." );
				self.decir( "°Pues claro!. No os retrasÈis m·s, Ulfius, °partid ahora!
				             Yo emprenderÈ la marcha en cuanto me recupere un poco."
				);

				arrancarReloj( self, 10 );

				rtrue;
		     }
	]
;

! ---------------------------------------------------------------------------
! El confidente
! ---------------------------------------------------------------------------

Personaje confidente limbo
! Estado 0 - Parado
! Estado 1 - Llegando
! Estado 2 - En la orilla, no ha hablado contigo
! Estado 3 - Ha hablado contigo
with
	elNombre "hombre de negro",
	pasaANombrePropio [;
		self.elNombre = "Mark";
		self.Personaje::pasaANombrePropio();
	],
	nombre_corto "hombre de negro",
	nombre 'confidente' 'traidor' 'barquero' 'mark' 'hombre' 'remero' 'barca' 'bote',
	descripcion "Se trata de un hombre que obviamente no quiere que
	             lo reconozcan. Viaja en un pequeÒo bote de remos, ahora
	             atracado en el embarcadero.",
	estaLLegando [;
		return ( self.estado == 1 );
	],
	cambiarEstado [;
		if ( localizacion == ROMPIENTE_OESTE
		  && self.estado == 0 )
		{
			self.estado = 1;
			arrancarReloj( self, 2 );
			"Escuchas un golpe sordo, atenuado, como de remos en el agua.";
		}

		if ( parent( self ) ~= limbo
		  && localizacion ~= parent( self ) )
		{
			if ( self.estado < 3 ) {
				self.estado = 0;
			}

			pararReloj( self );
			move self to limbo;
		}

		if ( parent( self ) == limbo
		  && self.estado == 3 )
		{
			pararDaemon( self );
		}
	],
	tiempo_restante 0,
	tiempo_agotado [;
		if ( localizacion == ROMPIENTE_OESTE ) {
			self.estado++;
			move self to ROMPIENTE_OESTE;
			"Un bote toca el embarcadero quedamente. El remero, vestido de negro, espera.";
		}
	],
	conversacion [;

		if ( self.estado == 2  ) {
			jugador.decir( "øSois vos el confidente?" );
			self.decir( "No, soy tu hada madrina, britano." );

			print "^A ninguno de vosotros tres parece haberle hecho gracia la salida...^";

			self.decir( "Pongamos que me llamo ~Mark~" );
			self.pasaANombrePropio();

			jugador.decir( "Est· bien, Mark, øtenÈis algo para mi?" );
			self.decir( "SÌ, tenÈis que rodear el castillo. En su parte trasera encontrarÈis un
			             t˙nel, y a su fin, un portillo sin vigilancia."
			);

			print (_El) self, " os alcanza algo...^";

			self.decir( "NecesitarÈis Èsto para atravesar el t˙nel." );
			move chisquero to jugador;

			print (_El) self, " os alcanza otra cosa...^";

			self.decir( "...y Èsta es la llave del portillo." );
			move llavePortillo to jugador;

			self.decir( "Para poder entrar en el t˙nel necesitarÈis una barra para poder
			             levantar con ella unos tablones a modo de cierre. La ocultan en
			             los rompientes, para que a˙n teniendo la llave, no pueda entrar
			             cualquiera."
			);

			self.estado++;
		}
		else
		if ( self.estado == 3 ) {
			jugador.decir( "øAlgo m·s que deba saber?" );
			self.decir("Je... bueno, el Rey Uther est· detr·s de ti." );
			print "^...el hombre lanza una risa contenida";
			wait( "...^" );
			jugador.decir( "Muy amable." );
		}
	],
	antes [;
		meterse:
			print "El remero te bloquea el paso...^";
			self.decir( "De eso, nada, britano" );
			rtrue;
	]
;

! -----------------------------------------------------------------------------
! Los guardias del castillo de Cornualles
! -----------------------------------------------------------------------------
class SoldadoCastilloCornualles
class Personaje
with
	elNombre "guardia",
	descripcion "Lleva un uniforme caracterÌstico, verde y naranja.",
	cambiarEstado [;
		if ( parent(self) == localizacion
		  && uniformes hasnt puesto )
		{
			print "^^", (el) self, " os detienen, al observar que no pertenecÈis al castillo.^";
			banderafin = 1;
			rtrue;
		}
	],
	conversacion [;
		print (_El) self;
		if ( self hasnt nombreplural )
			print " inclina la cabeza y saluda. Est· claro que est· de servicio y no quiere
		                   hablar con nadie.^";
		else print "  inclinan la cabeza y saludan. Est· claro que est·n de servicio y no quieren
		                   hablar con nadie.^";

		rtrue;
	]
;

Gente oficialesDespacho "oficiales del castillo" DESPACHO_DEL_OFICIAL_DE_GUARDIA
with
	elNombre "oficiales",
	nombre_mp 'oficiales' 'soldados',
	genero G_MASCULINO + G_PLURAL,
	nombre_corto "oficiales",
	descripcion "Varios oficiales discuten acaloradamente acerca de la defensa del castillo.",
	conversacion [;
		"Est·n demasiado entretenidos con su discusiÛn.";
	]
has nombreplural;

SoldadoCastilloCornualles oficialDeGuardia "oficial de guardia" DESPACHO_DEL_OFICIAL_DE_GUARDIA
! Estado -- lleva la cuenta de turnos
private
	iniciado false,
with
	elNombre "oficial de guardia",
	estaIniciado [;
		return self.iniciado;
	],
	prepararOficialDeGuardia [;
		self.iniciado = true;
		self.estado = 0;
	],
	cambiarEstado [;
		self.estado++;

		if ( self.estado == 20 ) {
			if ( localizacion == ARMERIA
			  || localizacion == PASILLO_DE_SERVICIO
			  || localizacion == DESPACHO_DEL_OFICIAL_DE_GUARDIA
			  || localizacion == TORREON )
			{
				print "^Desde tu posiciÛn en ";

				if ( localizacion has femenino )
					 print "la ";
				else print "el ";

				imprimeCadenaMinusculas( localizacion.nombre_corto );
				print ", ves como el oficial de guardia
                                           sale";

                                    if ( localizacion ~= DESPACHO_DEL_OFICIAL_DE_GUARDIA ) {
                                           print " de su despacho";
                                    }

                                    print " a grandes zancadas,
				  atraviesa el pasillo
                                           y entra ";

                                    if ( localizacion == TORREON )
                                           print "...^";
                                    else   print "en el torreÛn...^";
			}

			move self to TORREON;
			arrancarReloj( self, 4 );
			rtrue;
		}
	],
	tiempo_restante 0,
	tiempo_agotado [;
		if ( localizacion == ARMERIA
		  || localizacion == PASILLO_DE_SERVICIO
		  || localizacion == DESPACHO_DEL_OFICIAL_DE_GUARDIA
		  || localizacion == TORREON )
		{
                               print "^Desde tu posiciÛn en ";

                               if ( localizacion has femenino )
                                    print "la ";
                               else print "el ";

                               imprimeCadenaMinusculas( localizacion.nombre_corto );
			print ", ves como el oficial de guardia sale";

                               if ( localizacion ~= TORREON ) {
                                       print " del torreÛn sacudiendo la cabeza";
                               }

                               print ", atraviesa el pasillo y entra ";

                               if ( localizacion == DESPACHO_DEL_OFICIAL_DE_GUARDIA )
                                       print "...^ ";
                               else    print "en su despacho...^";
		}

		self.estado = 0;
		move self to DESPACHO_DEL_OFICIAL_DE_GUARDIA;
		rtrue;
	],
	nombre 'oficial' 'guardia',
	descripcion "Es un hombre rudo, delgado... aparentemente tiene muchas preocupaciones,
	             su vista deambula de un objeto a otro contÌnuamente.",
	conversacion [;
		jugador.decir( "Mi seÒor..." );
		self.decir(
			"Retornen a sus puestos, soldados, no sabemos cuando atacar· Uther este castillo."
		);
	],
	reaccionar_antes [;
		coger:
			if ( uno == llaveMaestra ) {
				print (_El) self, " se yergue indignado...";
				self.decir( "°No podÈis llevaros la llave maestra!" );
				jugador.decir( "Lo siento, capit·n, nosotros..." );
				self.decir( "øEs que no tenÈis ocupaciones que atender...?°Marchaos!" );
				rtrue;
			}
	]
;

SoldadoCastilloCornualles guardiaTorre "soldado de la torre" TORREON
! Estado 0 -- No hablÛ contigo
! Estado 1 -- HablÛ contigo
with
	elNombre "soldado de la torre",
	nombre 'soldado' 'guardia' 'torre',
	conversacion [;
		if ( oficialDeGuardia in parent( self ) ) {
			"El guardia est· m·s erguido que de costumbre, mira de reojo al oficial y
			       hace discretos movimientos negativos con la cabeza.";
		}

		if ( self.estado == 1 ) {
			jugador.decir( "Escucha..." );
			self.decir( "Calla, calla, el oficial de guardia podrÌa venir en cuaqluier momento..."
			);
			rtrue;
		}

		jugador.decir( "Hola, soldado..." );
		self.decir( "°Hola...! Vaya, no recuerdo haberos visto antes por aquÌ..." );
		jugador.decir( "...errr..." );
		print "El soldado suspira...";

		self.decir( "Perdona, ˙ltimamente estamos un poco paranoicos..." );
		self.decir( "El oficial de guardia no deja de venir aquÌ de vez en cuando, como si
		             fuesen a atacar esta noche..."
		);

		self.estado++;
	]
;

! -----------------------------------------------------------------------------
! Las patrullas dentro del castillo
! -----------------------------------------------------------------------------

class Patrulla
class MovilLineal
class SoldadoCastilloCornualles
private
	turnosPorLocalidad 2,
with
          siguienteLoc [loc mov toret;
              toret = Nothing;

              if ( mov == obj_o ) {
                  toret = loc.al_o;
              }
              else
              if ( mov == obj_e ) {
                  toret = loc.al_e;
              }
              else
              if ( mov == obj_n ) {
                  toret = loc.al_n;
              }
              else
              if ( mov == obj_s ) {
                  toret = loc.al_s;
              }

              return toret;
          ],
	nombre_f 'patrulla' 'soldados' 'guardias',
	nombre_mp 'soldados' 'guardias',
	genero G_MASCULINO + G_PLURAL,
	nombre_corto "soldados de patrulla",
	descripcion "Es un grupo de soldados del castillo.",
	iniciar [;
		self.Personaje::Iniciar();
	],
	daemon [;
		self.Personaje::daemon();
		self.MovilLineal::daemon();
	],
	despuesDeMoverse [;
		if ( localizacion == parent( self ) ) {
		    "Una patrulla de soldados se acerca...";
		}
	]
has nombreplural;

Patrulla patrullaSur PASILLO_SUROESTE
with
	iniciar [;
		self.Patrulla::Iniciar();
		self.arrancarMovil( dir_ESTE, PASILLO_SURESTE );
	],
	despuesDeParar [;
		if ( self in PASILLO_SURESTE )
			self.arrancarMovil( dir_OESTE, PASILLO_SUROESTE );
		else 	self.arrancarMovil( dir_ESTE, PASILLO_SURESTE );
	]
;

Patrulla patrullaNorte PASILLO_NORESTE
with
	iniciar [;
		self.Patrulla::Iniciar();
		self.arrancarMovil( dir_OESTE, PASILLO_NOROESTE );
	],
	despuesDeParar [;
		if ( self in PASILLO_NOROESTE )
			self.arrancarMovil( dir_ESTE, PASILLO_NORESTE );
		else 	self.arrancarMovil( dir_OESTE, PASILLO_NOROESTE );
	],
	despuesDeMoverse [;
		if ( localizacion == COCINAS
		  && parent( self ) == PASILLO_NORESTE )
		{
			"Oyes unos pasos fuera... °parece que se trata de soldados!";
		}

		self.Patrulla::despuesDeMoverse();
	],
	antesDeMoverse [;
		if ( localizacion == COCINAS
		  && parent( self ) == PASILLO_NORESTE )
		{
			print "Los pasos de lo que crees son soldados se alejan...^";
		}

		return self.Patrulla::antesDeMoverse();
	],
;

