class Neno
class Personaje
with
	antes [;
		atacar:
			print "°QuÈ verg¸enza...! Atacar a un niÒo...^";
			print "Eres uno de los caballeros del Rey, ampliamente conocido.";
			print "Pronto har·n llamar a la guardia del Rey. Y entonces ser·s historia.^";
	],
	esUnNuevoDia [ dia;
		if ( ( dia % 2 ) == 0 )
				move self to limbo;
		else	move self to CALLE_AL_ESTE_DE_LA_PLAZA;
	]
;

responde jugadoresDeCuerda
private
	elementos
