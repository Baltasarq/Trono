		print " es un jovenzuelo, mal vestido y mal nutrido, que intenta
		        aparentar ser el m·s duro de los ladrones.^";
	]
;

Ladron kareth limbo
with
	elNombre "espadachÌn",
	pasaANombrePropio [;
		self.elNombre = "Kareth";
		self.Personaje::pasaANombrePropio();
	],
	nombre_corto "espadachÌn",
	nombre 'kareth' 'espadachÌn',
	descripcion [;
		self.cabecera();
		print " es un ladrÛn que ciÒe una espada al cinto. La espada es,
		        en realidad, de las que se pueden conseguir por algunas
		        monedas, no las nobles espadas de combate de un caballero.^";
	]

;

Ladron sulfurius limbo
	! Estado = 0 Tranquilo
	! Estado = 1 Cabreado
with
	elNombre "arquero",
	pasaANombrePropio [;
		self.elNombre = "Sulfurius";
		self.Personaje::pasaANombrePropio();
	],
	nombre_corto "arquero",
	nombre 'Sulfurius' 'arquero',
	descripcion [;
		self.cabecera();
		print " es un arquero renegado. Descubres r·pidamente entre sus
		        ropas, tras una simple mirada, los restos del equipamiento
		        de los arqueros del Rey.^";
	],
	conversacion [;
		if ( jugador.esInvisible() ) {
			jugador.decir( "Buen hombre..." );
			print (_El) self, " mira a derecha e izquierda...^";
			self.decir( "Jefe, yo sigo sin verlo, no sÈ cÛmo lo haces." );
			stolinius.decir( "Por eso yo soy el jefe, truh·n..." );
			rtrue;
		}

		if ( self.estado == 0 )
		{
			jugador.decir( "°Vos fuisteis arquero del Rey...!°TenÈis que ayudarme!" );
			self.decir( "øArquero del Rey...? Eso fue hace mucho..." );
			self.decir( "Ahora sÛlo me preocupo de mi mismo, de vivir mi propia vida." );

			print "^Las risotadas del grupo corean las de ";
			self.cabecera( self.sinCambioLinea );
			print ".^";

			jugador.decir( "Malvivir, querrÈis decir..." );
			self.decir( "Vigilad vuestra lengua... a˙n estamos a tiempo de
			             arrancaros la piel a tiras." );

			print "~Vivir mi propia vida~, piensas, ~no como ladrÛn, claro, pero...~^";
		}
		else
		if ( self.estado == 1 ) {
			jugador.decir( "°TenÈis que ayudarme!" );
			jugador.decir( "°Viajo por una misiÛn del Rey!" );
			self.decir( "Est·is empezando a aburrirme con vuestra
			             charlatanerÌa, seÒor." );
			jugador.decir( "Una vez, jurasteis servir al rey..." );
			self.cabecera();
			print " no contesta. Parece realmente irritado con vos.
			      Os vigila de una forma realmente amenazadora.^";

			print "^~øCÛmo es posible que un dÌa sirviera al rey y ahora
			       sea un ladrÛn... ~, piensas,
			       ~øes que ya nadie guarda valores?~^
			       ~Ni siquiera tu propio rey~, te contestas a ti mismo.^";
		}
		else {
			jugador.decir( "°TenÈis que ayudarme!" );
			jugador.decir( "°Es vuestro Rey!, øo v·is a ser un traidor
			                toda vuestra vida?"
			);
			self.decir( "°Ya es suficiente!" );

			print "^Los ladrones te atacan. Son demasiados, y no est·is
			        suficientemente armado...^";

			banderafin = 1;
		}

		self.estado++;
	]
;

Ladron Stolinius limbo
private
	yaRobado false,
with
	elNombre "jefe de los ladrones",
	pasaANombrePropio [;
		self.elNombre = "Stolinius";
		self.Personaje::pasaANombrePropio();
	],
	yaHaSidoRobado  [;
		return self.yaRobado;
	],
	ponYaRobado [;
		self.yaRobado = true;
	],
	articulo "al",
	nombre_corto "jefe de los ladrones",
	nombre 'stolinius' 'jefe',
	descripcion [;
		self.cabecera();
		" parece el jefe del grupo. Es con diferencia el m·s grande de todos.
		Exhibe un burlona sonrisa en su rostro.";
	],
	hazEntrada [obj encontradoAlgo;
		self.cabecera();
		print " aparece de entre los ·rboles.^Te habla, recalcando ciertas palabras...^";

		self.decir ( "Hola, viajero, ~feliz~ dÌa. Me llamo Stolinius, y soy el jefe de
		              este ~grupo de recaudaciÛn~ que trata de recolectar dinero para los pobres.^
		              Espero que desees ~colaborar~ con nosotros.^
		              Te presento a mi espadachÌn Kareth, mi arquero Sulfurius, y el hermano
		              de Kareth, Sareth, que est· aprendiendo el oficio..."
		);

		if ( jugador.esInvisible() ) {
			self.decir( "A mi no me las das con esos trucos de mago barato..." );
			print "^No sabes cÛmo lo ha hecho, pero te ha atrapado a pesar
			       de ser invisible...^";
		}

		if ( self.yaHaSidoRobado() ) {
			self.decir( " ...pero... °un momento...!°Si es nuestro amigo...! Debo
			            admirar tu espÌritu de colaboraciÛn con la ~causa~."
			);

			if ( jugador.esInvisible() ) {
				print "^°Es imposible...!°Eres invisible ahora!^";
			}
		}

		self.ponyaRobado();
		self.pasaANombrePropio();
		kareth.pasaANombrePropio();
		sareth.pasaANombrePropio();
		sulfurius.pasaANombrePropio();

	    ! Lo que lleva el prota
		encontradoAlgo = false;
		objectloop ( obj ) {
			if ( obj in jugador
			  && obj ofclass DejadoDesaparecido )
			{
				encontradoAlgo = true;
				print "^...arranca ", (el) obj, " de entre tus ropas.^";

				if ( obj == BOLSA ) {
					self.decir( "°Vaya muchachos, debe de ser un
					             mensajero del rey...!
					             °Mirad quÈ botÌn!"
					);
				}

				move obj to limbo;
			}
		}

		! Lo que ha dejado en la localidad
		objectloop ( obj ) {
			if ( obj in localizacion
			  && obj ofclass DejadoDesaparecido )
			{
				encontradoAlgo = true;
				print "^...recoge ", (el) obj, " del suelo.^";

				if ( obj == BOLSA ) {
					BOLSA.fueRobada = true;
					self.decir( "°Vaya muchachos, debe de ser un
					             mensajero del rey...!
					             °Mirad quÈ botÌn!"
					);
				}

				move obj to limbo;
				obj.lugarDondeLaDejaste = limbo;
			}
		}


		if ( ~~encontradoAlgo ) {
			print "Busca algo de valor entre tus ropas... y no lo encuentra.";
			self.decir( "Asqueroso pat·n... °l·rgate, antes de que me haga un abrigo nuevo con tu trasero!" );
		} else {
			self.decir( "Gracias, caballero, cualquier riqueza o comida son
			             necesarias para la ~causa~."
			);
		}
	],
	conversacion [x;

		if ( jugador.esInvisible() ) {
			print (_El) self, " te mira directamente. A Èste maleante no le engaÒa la pociÛn...^";
		}

		if ( self.estado == 0 )
		{
			jugador.decir( "Estoy en misiÛn del Rey Uther, y..." );
			self.decir( "ø° Y a mi que me cuentas, pollo !?, anda y llÛrale a tu Rey Uther, si quieres." );
			print "...las carcajadas son coreadas por el resto del grupo...^";
			self.decir( "Por cierto, si te d· m·s oro, no te olvides de volver por aquÌ..." );
			self.estado++;
		}
		else
		if ( self.estado == 1 )
		{
			jugador.decir( "Yo no puedo..." );
			print "^Stolinius corta vuestro discurso desenfundando su espada
			       y apunt·ndola hacia vos.^"
			;

			if ( localizacion ~= CONTINUACION_DEL_CAMINO ) {
				self.cabecera();
				print " te obliga a caminar, siguiÈndole";
				wait( "...^" );
				jugadorA( CONTINUACION_DEL_CAMINO, 2 );
			}

			self.decir( "No me interesan los caballeros del Rey.
				No necesito precisamente que Uther PendragÛn se enoje
				conmigo.^AsÌ que marchaos y dad gracias por conservar
				vuestra vida. AdiÛs."
			);


			print "^Los ladrones se retiran por entre los ·rboles.^";

			objectloop ( x ofclass Ladron ) {
				move x to limbo;
				print (_El) x, " desaparece...^";
			}
		}
	]
;

!---------------------------------------------------------------------
! Lucrius, el vendedor del mercadillo
!---------------------------------------------------------------------

ServicioRey Lucrius limbo
class Vendedor
! Estado = 0 No ha hablado contigo
! Estado = 1 Ha hablado contigo
! Estado = 2 Te ha vendido algo
! El vendedor y su puesto deben desaparecer una vez que Lucius vuelve de su misiÛn
with
	elNombre "vendedor",
	pasaANombrePropio [;
		self.elNombre = "Lucrius";
		self.Personaje::pasaANombrePropio();
	],
	reset [;
		move bolsaDeComida to limbo;
		self.estado = 0;
		self.objetoAVender = bolsaDeComida;
	],
	nombre_corto "Lucrius",
	nombre 'Lucrius' 'vendedor' 'mercader' 'vendedores' 'mercaderes',
	descripcion [;
		self.cabecera();
		print " es un pequeÒo hombre gordo de mirada risueÒa.^";
	],
	objetoAVender bolsaDeComida,
	precio 3,
	cambiarEstado [;
		if ( self.objetoAVender == Nothing )
		{
			self.estado = 2;
		}
	],
	esUnNuevoDia [dia;
		if ( ( dia % 2 ) == 0 )
		{
			move self to limbo;
			move PUESTO_DE_FRUTA to limbo;
			move PUESTO_DE_FLORES to PLAZA_DEL_CASTILLO;
		}
		else {
			move self to PLAZA_DEL_CASTILLO;
			move PUESTO_DE_FLORES to limbo;
			move PUESTO_DE_FRUTA to PLAZA_DEL_CASTILLO;
		}
	],
	conversacion [;

		if ( jugador.esInvisible() ) {
			jugador.decir( "Buen hombre..." );
			print (_El) self, " mira a derecha e izquierda... sacude la cabeza...^";
			rtrue;
		}

		if ( self.estado == 0 )
		{
			jugador.decir( "Buenos dÌas." );
			self.decir( "Buenos dÌas, mi seÒor. Mi nombre es Lucrius, para servirle." );
			self.pasaANombrePropio();
			self.decir( "SÛlo puedo venderos estas bolsas preparadas para llevar, por 3 monedas de oro." );
			self.decir( "PodÈis depositar toda vuestra confianza en mi. Si querÈis comprar, COMPR¡DSELO A LUCRIUS." );
			self.decir( "...Perdonadme, debo atender a mis otros clientes..." );
			print "^el vendedor se dedica a atender a multitud de otros compradores...^";
			self.estado++;
		}
		else
		if ( self.estado == 1 ) {
			self.decir( "Mi seÒor, sÛlo puedo ofreceros lo que aquÌ vÈis. Si veis algo que os guste, no dudÈis
			             en COMPRARselo A Lucrius." );
		}
		else
		if ( self.estado == 2 ) {
			self.decir( "Mi buen seÒor, aquÌ nada tengo ya que os pueda interesar." );
			print "^Lucrius vuelve a atender a sus otros clientes.^";
		}

	]
has;

