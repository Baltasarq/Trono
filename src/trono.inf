has femenino nombreplural;

Objeto LLAVE "llave de oro" CALLEJON_DE_LA_FUENTE
with
	nombre 'llave',
	adjetivos 'oro',
	descripcion [;
		"Es una llave de oro,
	     cuya forma en un extremo captura la figura de una serpiente.";
	],
	despues [;
		coger:
			if ( PUERTA_CALLEJON_FUENTE has oculto
			  && localizacion == CALLEJON_DE_LA_FUENTE )
			{
				give PUERTA_CALLEJON_FUENTE ~oculto;
				"En el momento de coger la llave,
			 	se materializa una puerta al norte. Aunque quizás ya estaba ahí...^";
			}
	]
has femenino oculto;

Objeto LLAVE_PEQUENA "llave pequeńa" limbo
with
	nombre 'llave' 'pequena',
	descripcion "Es una pequeńa llave, nada más.",
	antes [;
		meter, ponerSobre:
			if ( otro == felpudo )
			{
				if ( self notin jugador ) {
					"Pero si no tienes la llave...";
				}

				move self to felpudo;
				print "Guardas cuidadosamente la llave bajo el felpudo...^";

				if ( jugador.fueMerlinEncontrado()
				  && PUERTA_EXPLANADA_DE_ROCA hasnt abierta )
				{
					print "^Repentinamente, te ves transportado por el aire,
						   envuelto por unas fuerzas invisibles.^";
					wait( "...^" );
					print "Sobrevuelas de esta forma el laberinto, para ir a parar
						   a su entrada";
					wait( "...^" );
					Conseguido( TAREA_LLAVE_MERLIN );
					jugadorA( PIE_DE_LA_MONTANA, 2 );
				}

				rtrue;
			}
	]
has femenino valepuntos;

ObjetoEstatico MECEDORA "mecedora" CABANA
with
	nombre 'mecedora' 'silla',
	antes [;
		examinar: rfalse;
		default:
			if ( mirlo in parent( self ) )
				"Mejor dejar en paz la silla al anciano, pobre hombre...";
			else "Mejor dejarla, no sea que Merlín se enfade.";
	],
	descripcion [;
		print "Es una vieja y decrépita mecedora, sin mayor interés.^";

		if ( mirlo in parent( self ) ) {
			print "El anciano se sienta sobre ella, haciéndola chirriar
			       cada vez que se mueve, trabajosamente.^";
		}
		else
		if ( merlin in parent( self ) ) {
			print "Merlín se sienta sobre ella, moviéndola vigorosamente y haciéndola
			       emitir chirridos que más parecieran quejidos o chillidos.^";
		}

		rtrue;
	]
has femenino;

Objeto POCION_PARA_INVISIBLE "poción verde" limbo
with
	nombre 'pocion' 'pocima' 'brebaje' 'verde'
	       'invisibilidad' 'botellita' 'frasco',
	descripcion "Es una poción de un líquido verde.",
	antes [;
		abrir:
			print "La abres, y ves que...^";
			<<examinar>>;
		beber:
			move self to limbo;
			jugador.hazInvisible();
			"Te bebes la poción y notas un hormigueo extrańo en todas las
			 extremidades... momentos después, una energía extrańa bulle
			 desde tus entrańas a tu cabeza... entonces, ~normalidad~
			 de nuevo.";
	]
has  femenino valepuntos;

Objeto MAPA "mapa" limbo
with
	nombre 'mapa' 'pergamino',
	descripcion "Contiene un dibujo de lo que parece ser un laberinto.
				El mapa te indica seguir, desde la entrada,
	             norte, norte, este, oeste, norte, norte.",
	antes [;
		robar:
			if ( self notin jugador ) {
				"żRobar ", (el) uno, "...?ˇEres un caballero, por Dios!^
			 	ˇżNo querrás robarle a otro caballero!?";
			}
		coger, examinar, buscarEn, empujar, tirar:
			if ( ~~tristan.fueMapaVendido() ) {
				if ( ~~jugador.esInvisible() ) {
					"Tristán te mira tristemente y aparta el mapa de tu alcance.";
				} else {
					print "Tristán asiste, atónito, a cómo el mapa desaparece de entre sus manos
					       de manera repentina.^
					       Rompe a llorar y sale de la cabańa corriendo, sin poder creer su mala
					       suerte.^
					       Injusto final para un caballero de su talla.^
					       Injusta misión la encomendada.^";
					PararDaemon( tristan );
					move tristan to limbo;
					rfalse;
				}
			}
	],
	despues [;
		coger: Conseguido( TAREA_CONSEGUIR_MAPA );
	]
has valepuntos;

