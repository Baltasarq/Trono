[ iniciarDecorados muestraNum num;
	num = iniciarDecoradosCalle();

    	if ( muestraNum ) {
		print "^Núm. calles: ", num, " remanentes: ", decoradoCalle.remaining();
	}

	num = iniciarDecoradosInteriorCueva();

	if ( muestraNum ) {
		print "^Núm. cuevas: ", num, " remanentes: ", decoradoInteriorCueva.remaining();
	}

	num = iniciarDecoradosMonte();

	if ( muestraNum ) {
		print "^Núm. montes: ", num, " remanentes: ", decoradoMonte.remaining();
	}

	num = iniciarDecoradosMontePedregoso();

	if ( muestraNum ) {
		print "^Núm. montes pedregosos: ", num, " remanentes: ", decoradoMontePedregoso.remaining();
	}

	num = iniciarDecoradosPalacio();

	if ( muestraNum ) {
		print "^Núm. habitaciones de palacios: ", num, " remanentes: ", decoradoPalacio.remaining();
	}

	num = iniciarDecoradosExteriorPalacio();

	if ( muestraNum ) {
		print "^Núm. localizaciones exterior de palacio: ", num, " remanentes: ", decoradoExteriorPalacio.remaining();
	}

	num = iniciarDecoradosLaberinto();

	if ( muestraNum ) {
		print "^Núm. habitaciones del laberinto: ", num, " remanentes: ", decoradoLaberinto.remaining();
	}

	num = iniciarDecoradosCasaMadera();

	if ( muestraNum ) {
		print "^Núm. casas de madera: ", num, " remanentes: ", decoradoCasaMadera.remaining(), "^";
	}

];

[ iniciarDecoradosCalle x nobj i;
	i = 0;

	objectloop ( x ofclass Calle ) {
		nobj = DecoradoCalle.create();
		move nobj to x;
		i++;
	}

	return i;
];

[ iniciarDecoradosMonte x nobj i;
	i = 0;

	objectloop ( x ofclass Monte ) {
		i++;
		nobj = DecoradoMonte.create();
		move nobj to x;

		nobj = DecoradoBosque.create();
		move nobj to x;
	}

	return i;
];

[ iniciarDecoradosMontePedregoso x nobj i;
	i = 0;

	objectloop ( x ofclass MontePedregoso ) {
		i++;
		nobj = DecoradoMontePedregoso.create();
		move nobj to x;
	}

	return i;
];

[ iniciarDecoradosInteriorCueva x nobj i;
	i = 0;

	objectloop ( x ofclass InteriorCueva ) {
		i++;
		nobj = DecoradoInteriorCueva.create();
		move nobj to x;
	}

	return i;
];

[ iniciarDecoradosPalacio x nobj i;
	i = 0;

	objectloop ( x ofclass Palacio ) {
		i++;
		nobj = DecoradoPalacio.create();
		move nobj to x;
	}

	return i;
];

[ iniciarDecoradosExteriorPalacio x nobj i;
	i = 0;

	objectloop ( x ofclass ExteriorPalacio ) {
		i++;
		nobj = DecoradoExteriorPalacio.create();
		move nobj to x;
