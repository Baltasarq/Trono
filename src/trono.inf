ConexionAbrible PUERTA_CALLEJON_FUENTE "puerta" CALLEJON_DE_LA_FUENTE
class ObjetoEstatico
with
	nombre_f 'puerta' 'serpiente',
	nombre_m 'dintel',
	genero G_FEMENINO,
	descripcion [;
		if ( localizacion == CALLEJON_DE_LA_FUENTE )
			"Alta... muy alta, casi como las murallas de este laberinto.
	             Está construida de hierro y madera.
	             En el dintel de la puerta, tallado en piedra,
	             puedes ver una extrańa figura...
	             es una curiosa serpiente,
	             sin marcas que puedan corresponderse con ojos o boca.";
	    else "Al sur, está la puerta del callejón de la fuente.";
	],
	laLLave llave,
	antes [;
		abrir:
			if ( llave in jugador ) {
				give self abierta;
				"Abres la puerta...";
			} else "Está cerrada con llave...";
	],
	reaccionar_antes [;
		entrar:
			if ( localizacion == CALLEJON_DE_LA_FUENTE ) {
				<<ir obj_n>>;
			}
		salir:
			if ( localizacion == TUNEL ) {
				<<ir obj_s>>;
			}
	]
has oculto femenino;

Objeto PUERTA_CALLEJON_PUERTA "puerta" CALLEJON_DE_LA_PUERTA
with
	nombre_f 'puerta' 'placa' 'lengua' 'serpiente',
	genero G_FEMENINO,
	nombre_m 'dintel' 'simbolo',
	descripcion "Una alta puerta de hierro, en cuyo dintel ves una serpiente
	             como las anteriores, con una detallada lengua bífida,
	             tallada en una placa de hierro.",
	antes [;
		cerrar:
			if ( llave in jugador )
			{
				give self ~abierta;
				"Cierras la puerta...";
			} else "Para eso necesitarías la llave...";
		quitarcerrojo:
			if ( otro ~= llave ) {
				"No conseguirás abrirla así...";
			}

			<<abrir self>>;
		abrir:
			if ( llave in jugador ) {
				give self abierta;
				"Abres la puerta...";
			} else "Está cerrada con llave...";
	],
           pasar [;
        		if ( self hasnt abierta ) {
        			"No puedes pasar a través de la puerta...";
        		}

		print "...te internas en una inquietante oscuridad";
		wait( "...^" );
		print "Repentinamente, pareces caer y caer sin fin";
		wait( "...^" );
		print "Vuelves en ti... estás en";
		wait( "...^" );
		jugadorA( ENTRADA_DEL_BOSQUE ,2 );
		rtrue;
	],
	reaccionar_antes [;
		ir: if ( uno == obj_n ) {
				return self.pasar();
		    }
		entrar: <<ir obj_n>>;
	]
has estatico femenino ;

ConexionAbrible PUERTA_EXPLANADA_DE_ROCA "puerta" EXPLANADA_DE_LA_ROCA
class ObjetoEstatico
with
	nombre_f 'puerta' 'serpiente' 'entrada',
	nombre_m 'dintel',
	genero G_FEMENINO,
	descripcion [;
	    if ( localizacion == EXPLANADA_DE_LA_ROCA )
		"Al norte se sitúa una sencilla puerta de madera, con una serpiente tallada en
	             su dintel. Un pequeńo felpudo reposa justo bajo ella.";
	    else "Al sur, una puerta permite salir de esta especie de cueva.";
	],
	laLLave llave_pequena,
	antes [;
		quitarCerrojo:
			if ( otro == llave_pequena ) {
				<<abrir self>>;
			}

			"No conseguirás abrir la puerta con ", (el) otro, ".";
		abrir:
			if ( llave_pequena in jugador ) {
				give self abierta;
				"Abres la puerta...";
			} else "Está cerrada con llave...";
	],
	reaccionar_antes [;
		entrar:
			if ( localizacion == EXPLANADA_DE_LA_ROCA ) {
				<<ir obj_n>>;
			}
		salir:
			if ( localizacion == GUARIDA_DE_MERLIN ) {
				<<ir obj_s>>;
			}
	]
has femenino;

