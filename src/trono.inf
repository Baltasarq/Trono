	return i;
];

[ iniciarDecoradosCasaMadera x nobj i;
	i = 0;

	objectloop ( x ofclass CasaMadera ) {
		i++;
		nobj = DecoradoCasaMadera.create();
		move nobj to x;
	}

	return i;
];
