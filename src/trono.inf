ObjetoEstatico felpudo "felpudo" EXPLANADA_DE_LA_ROCA
with
	nombre 'felpudo',
	descripcion "Es un felpudo basto, hecho con lana de oveja.",
	antes [;
		buscarEn, empujar, tirar, MirarDebajo, agitar, atacar:
			if ( LLAVE_PEQUENA in felpudo
			  || LLAVE_PEQUENA in limbo )
			{
				move LLAVE_PEQUENA to jugador;
				"De debajo del felpudo aparece una pequeńa llave, que
				 tomas para ti.";
				}
		coger, vaciar:
			"Mejor dejarlo, es de Merlín...";
		Recibir: "żˇEn el felpudo!?";
	],
	reaccionar_antes [;
		examinar:
			if ( uno == obj_abajo ) {
