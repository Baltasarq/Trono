objeto antorcha "antorcha" TUNEL_DE_ESCAPE
with
	nombre 'antorcha' 'llama' 'luz',
	descripcion [;
                if ( self hasnt luz ) {
                    "Podría ser encendida para dar luz,
                     aunque está bastante húmeda.";
                }
                "Un tanto vieja y húmeda.";
          ],
	antes [;
		apagar:
			if ( self has luz )
				"Mejor no arriesgarse a apagarla...";
			else 	"No está encendida.";
		quemar, encender:
			if ( self has encendida ) {
				"Ya la encendiste antes...";
			}

			if ( chisquero in jugador ) {
				give self luz;
				give self encendido;
				"Enciendes la antorcha, que crepita y lanza una densa humareda...";
			}
			else "Necesitas tener algo para encenderla...";
	],
	reaccionar_antes [;
		if ( localizacion == MURO_TRASERO_DEL_CASTILLO
		  || localizacion == ROMPIENTE_OESTE
		  || localizacion == ESQUINA_NORESTE_DEL_CASTILLO
		  || localizacion == CAMINO_DE_RONDA_ESTE
		  || localizacion == CAMINO_DE_RONDA_OESTE )
		{
		      if ( self has luz ) {
			print "^^Escuchas unos gritos en el almenar del castillo.
			       Pronto te das cuenta de la razón: llevas la antorcha encendida,
			       indicándole vuestra posición a todos los guardias del castillo.
			       Estáis perdidos.
			^^";

			banderafin = 1;
			rtrue;
		      }
		}
	],
	despues [;
	      dejar:
                  if ( self has luz ) {
		give self ~luz;
		give self ~encendido;
		"Al contacto con la húmeda piedra de la cueva, la antorcha se consume lentamente,
		        	hasta que se apaga totalmente...";
                  }
	]
has femenino conmutable;

Objeto uniformes ALMACENES
with
	nombre_corto "uniformes",
	nombre_mp 'uniformes',
	genero G_MASCULINO + G_PLURAL,
	nombre_m 'uniforme',
	descripcion "Son uniformes como los de los soldados de este castillo.",
	antes [;
		vestir:
			self.genero = G_MASCULINO;
			self.nombre_corto = "uniforme";
			self.descripcion = "Es un uniforme verde y naranja.";
	],
	despues [;
		coger:
			uther.decir( "ˇSon uniformes como los de la soldadesca del castillo!" );
		vestir:
			print "^El Rey Uther también se pone uno.^";
			uther.decir( "ˇBuena idea, Ulfius!, con este disfraz pasaremos inadvertidos." );
		desvestir:
			uther.decir( "Ulfius, no creo que sea una buena idea." );
		dejar:
			uther.decir( "Ulfius, ˇnos descubrirán!" );
	]
has nombreplural prenda;

