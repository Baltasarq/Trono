	             miga en el interior.",
	reaccionar_antes [;
	    if ( self has oculto ) {
	        if ( ( uno == self
	            || otro == self )
	          && accion ~= ##Examinar
	          && accion ~= ##Comprar )
	        {
	            print "Primero deberás comprar ", (el) self, ".^";
	            rtrue;
	        }
	    }
	],
	antes [;
	          coger:
	              if ( self has oculto ) {
	                  "Puedes comprarlo, que no cogerlo directamente...";
	              }
		comer: "Aún no es el momento de comer...";
	]
has femenino comestible oculto;

