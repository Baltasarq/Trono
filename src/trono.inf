respondeUnaVez beberFuente
private
	elementos
		"Tú veras, pero... mira que el caballo está bebiendo de ahí..."
		"Sí seńor muy fresca y agradable... con un regustillo a babas de caballo,
		 pero bueno..."
;

ObjetoEstatico FUENTE "fuente" POZO
with
	nombre_f 'fuente',
	nombre_m 'agua' 'charco',
	genero G_FEMENINO,
	descripcion "El agua cristalina que vierte en ella calmará la sed del caballo.
	             Junto a la fuente, en el otro extremo...
	             un hombre que por su vestimenta aparenta ser un caballero.",
	antes [;
	  beber:
		print (string) beberFuente.dev_msg(), "^";
		rtrue;
	],
	reaccionar_antes [;
		lanzar, ponerSobre:
			if ( uno == seta
			  && otro == self )
			{
				print "^El caballero se da cuenta de tu acción...^";
				caballeroNegro.decir( "ˇAh, felón...!żpretendíais envenenarme?" );
				<<atacar caballeroNegro>>;
			}
	]
has  femenino;

ObjetoEstatico POZO_ARTESANO "pozo" POZO
with
	nombre 'pozo',
	descripcion
		"El pozo no tiene casi ningún interés. Le faltan la cuerda y el cubo,
		 por lo que es de mucha mejor utilidad la fuente natural a su lado.",
	antes [;
		buscarEn:
			"Al fondo, puedes distinguir el tenue reflejo del agua. Cuando sacas la cabeza,
			 aprecias que el caballero te mira fijamente mientras sacude la cabeza...";
	]
has;

