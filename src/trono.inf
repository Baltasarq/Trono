! =============================== Personajes===================================

Include ">personajesTrono.inf";

! ============================== CORTOS =======================================

CortoMetraje cortoInicio
with
	descripcion
		[;
			self.Delay = 5;
			clearMainWindow();
			print (s_bold) "^Westmorland...^";
			print (s_underline) "c. 400 d.c.^^^";

			kay.decir( "Mi seńor Ulfius.... ˇMi seńor Ulfius...!" );
			kay.decir( "ˇUlfius!" );
			jugador.decir( "...!?... żEh...?żKay...?żQué... qué sucede?" );
			jugador.decir( "..." );
			kay.decir( "ˇMi seńor Ulfius! ˇEl rey Uther os convoca! ˇDebéis acudir cuanto antes a palacio!" );
			jugador.decir( "żˇQué sucede...!?żSon los Sajones de nuevo?" );
			kay.decir( "...creo que no, mi seńor... Westmorland está a salvo... pero... ˇdaos prisa!" );
			jugador.decir( "Está bien, está bien, acudiré en cuanto me vista." );
		]
		"^Kay abandona tu casa, casi precipitadamente^..."
		"^Aún tratando de despertar del todo, te pones tus ropas. El sol apenas ha salido cuando
		 abandonas tu hogar y te diriges al castillo.^..."
		"^Recorres un breve trecho hacia el sur y hacia el oeste desde tu casa.^..."
		"^Entras en el castillo, y recorres el pasillo principal..."
		"^La sala del trono, a pesar de lo temprano que es, está casi llena..."
		"^Esto no puede indicar nada bueno.^..."
;

! ====================================== El final de la aventura =============
CasaMadera TU_NUEVA_CASA "Tu nueva casa"
with
          al_e "No es el momento.",
	descripcion "Una pequeńa casa de granjero, de una sola estancia, la cuál
	             sirve como cocina, y sala de estar según la
	             pared que se escoja y el grueso cortinaje que se corra.
	             La única habitación separada por un tabique de troncos de
	             madera, de la misma factura que las paredes exteriores de
	             la casa, es el dormitorio, en la parte este.
	             "
;

ObjetoEstatico puertaNuevaCasa "puerta" TU_NUEVA_CASA
with
    nombre 'puerta',
    descripcion [;
        print "Pues sí, ahí donde la ves, la puerta de tu casa.";
        if ( self has abierta )
                print " Está abierta.^";
        else    print "^";

        rtrue;
    ],
    antes [;
        cerrar:
            "Tienes cosas más importantes de las que ocuparte ahora mismo...";
        abrir:
           if ( self hasnt abierto ) {
               give self abierto;
               epilogo2();
               rtrue;
           } else "La puerta está ya abierta... y Merlín frente a ti.";
    ]
has femenino;

ObjetoEstatico cortinajesNuevaCasa "cortinajes" TU_NUEVA_CASA
with
    nombre_mp 'cortinajes',
    nombre_fp 'cortinas' 'divisiones',
    nombre_f 'cortina',
    nombre_m 'cortinaje',
    genero G_MASCULINO + G_PLURAL,
    descripcion
        "Permiten hacer pequeńas divisiones dentro de la casa,
         según se necesiten ciertas funciones u otras."
;

ObjetoEstatico bebe "bebé" limbo
with
    nombre 'bebe' 'nino',
    descripcion
        "Un pequeńo e indefenso nińo se retuerce entre el ropaje de Merlín.",
    antes [;
        examinar: rfalse;
        coger: "Merlín lo protege con fuerza.";
        default: "Merlín sostiene al nińo entre sus brazos y lo protege.";
    ]
;

ObjetoEstatico cocinaNuevaCasa "cocina" TU_NUEVA_CASA
with
    nombre 'cocina',
    descripcion
        "Una aparatosa cocina de leńa se encuentra en una de las partes de la
         casa."
has femenino;

ObjetoEstatico dormitorioNuevaCasa "dormitorio" TU_NUEVA_CASA
with
    nombre 'dormitorio',
    descripcion
        "Se encuentra en la parte este de la casa, y es la única habitación
         separada del resto por un tabique real.^
         Tu mujer se encuentra descanasado allí ahora, tras una dura jornada."
;

[ epilogo1 x;
	clearMainWindow();
	print (s_bold) "Epílogo";

	! Poner todos los objetos en el limbo
	objectloop ( x ) {
	    if ( x in jugador ) {
	        move x to limbo;
	    }
	}

	! Comenzar el epílogo
	print "^^Ha pasado mucho tiempo desde aquellos acontecimientos.^
	       Por un lado casi se han desvanecido, deformado y empańado en tu
	       mente... por el otro, prefieres no hacer ningún esfuerzo por
	       recordarlos.^^";
	jugadorA( TU_NUEVA_CASA, 2 );

	print "^Es de noche, y llueve. Descansas después de una larga jornada
	       de trabajo";
	wait( "...^" );

	print "^Alguien llama a la puerta.^Qué extrańo";
	wait( "...^" );
];

[ epilogo2;
	move Merlin to localizacion;
	move bebe to localizacion;

	print "^Abres la puerta.^Frente a tí, un anciano, con una larga túnica y un cinto por
	       toda vestimenta, sostiene a un bebé en sus brazos.^
	       El anciano entra en la casa.^";
	wait( "...^" );
];

[ epilogo3;
	print "^Llamas a tu esposa...^";
	jugador.decir( "Carińo, debo contarte algo..." );

	banderafin = 2;
	print (s_bold) "^^^Fin.^";
];


! ====================================== Gramática ===========================
[xyzzySub dest;

	if ( merlin in localizacion ) {
		merlin.decir( "ˇLas manos quietas...! Para mago yo, caballero." );
	}
	else
	if ( localizacion == CUEVA_PROFUNDA )
	{
		print "Un ligero temblor sacude la cámara";
		wait( "...^" );
		print "Los restos humanoides tiemblan con el poder de la palabra";
		wait( "...^" );
		print "Las manos del esqueleto alzan las hachas en el aire, con renqueante inseguridad";
		wait( "...^" );
		"Repentinamente, el temblor se detiene, y las manos del esqueleto parecen
		 perder su fuerza, desplomándose las hachas hasta el suelo.^";
	}
	else
	if ( localizacion == LAGO
	  || localizacion == COLINA )
	{
		print "^Te ves envuelto en una extrańo vapor";
		wait( "...^" );

		print "te elevas por el
		       aire y caes, aturdido, en";
		wait( "...^" );

		dest = LAGO;

		if ( localizacion == LAGO ) {
			dest = COLINA;
		}

		jugadorA( dest, 2 );
	}
	else print "No sucede nada, aparentemente.^";

	rtrue;
];

[ayudaSub;
	print "^Las órdenes siguientes son básicas y puede encontrarse
	  en casi cualquier aventura conversacional.
	  Pueden introducirse en infinitivo, imperativo, y en ocasiones,
	  que se seńalan con la opción entre paréntesis, reducir la orden
	  a una o dos letras.
	  El jugador puede tratar siempre de hacer otras acciones.^^";
	wait( "...^" );
	print (s_fixed)
	 "Ayuda              -   Esta ayuda.^
	 (n)orte            -   Ir al norte (adelante).^
	 (s)ur              -   Ir al sur (atrás).^
	 (e)ste             -   Ir al este (derecha).^
	 (o)este            -   Ir al oeste (izquierda).^
	 arriba, subir      -   Ir arriba.^
	 abajo, bajar       -   Ir abajo.^
	 (ex)aminar x       -   Da una descripción de x.^
	 examinarme, xme    -   Información sobre tu misión y tú.^
	 (h)ablar con y     -   Permite comunicarse con y.^
	 (c)oge x, (d)eja x -   x pasa a ser o deja de ser llevado.^
	 (i)nventario       -   Da una lista de los objetos llevados.^
	 dar x a y          -   Ofrece el objeto x al personaje y.^
	 comprale a y       -   Le compra al personaje y lo que tenga a la venta.^
	 puntos             -   Puntuación obtenida.^
	 puntos total       -   Puntuación detallada.^";
	wait( "...^" );
	print
	 "^^
	 Por Selena y Baltasar, el Arquero.
	 ^^
      Mándanos tus comentarios a: baltasarq@@64gmail.com
      y selenavirtual@@64yahoo.com.ar
      ^^
      Tú eres...
	^";
	<<examinar ulfius>>;
];

[ arrancarSub;
	"No parece que vaya a servir de mucho...";
];

[ levantarConSub;
	"No conseguirás nada levantando ", (el) uno, " con ", (el) otro;
];

[ robarSub;
	if ( uno in jugador ) {
		print "Veamos...^";
		<< inv >>;
	}

	print "Podríais probar a coger ", (el) uno," símplemente... veamos...^";
	<< coger uno >>;
];

[ venderSub;
	if ( otro == jugador ) {
		print "żVas a venderte ", (el) uno, " a ", (el) otro,"?^";
		rtrue;
	}

	if ( otro ~= Nothing ) {
			"No te has esforzado tanto para conseguir ", (el) uno,
			" como para vender o malvender alegremente.";
	}
	else 	"żA quién quieres vender?";
];

[ contarSub;
	if ( uno has nombreplural ) {
		if ( uno has femenino )
				"Más de una, seguro...";
		else		"Más de uno, seguro...";
	}
	else {
		if ( uno has femenino )
				"Una.";
		else 	"Uno.";
	}
];

Extend 'lanza' first
	* held -> Lanzar
	* held 'hacia' 'delante'/'adelante' -> Lanzar
	* held 'adelante' -> Lanzar
;

Extend 'habla' replace
  	* 'con' creature -> hablar
  	* 'a//' creature -> hablar
  	* 'al' creature -> hablar
;

Verb 'vende'
	* held 'a//' creature -> vender
;

Extend 'compra' replace
	* 'a//'/'al' creature -> comprar
  	* noun 'a//'/'al' creature -> comprar reverse
;

Extend 'pon' first
	* multiexcept 'bajo' noun -> Meter
	* multiexcept 'debajo' 'de' noun -> Meter
;

Verb 'roba'
	* noun -> robar
;

Verb 'arranca'
	* noun-> tirar
;

Verb 'xyzzy'
	* -> xyzzy
;

Verb meta 'ayuda' 'pistas'
	* -> ayuda
;

Verb 'levanta'
	* noun -> MirarDebajo
	* noun 'con' held -> levantarCon
;

Extend 'busca' first
	* 'entre' noun -> buscarEn
;

Extend 'trepa' first
    * -> Trepar
    * 'en' noun -> Trepar
;

Verb 'destrepa'
    * -> Bajar
    * noun -> Bajar
    * 'por' noun -> Bajar
;

Verb 'haz'
	* 'palanca' 'con' held 'en' noun -> levantarCon reverse
;
VerboIrregular "hacer" with imperativo 'haz';

Extend 'bebe' last
	* 'de' noun -> beber
;

Extend 'deja' last
	* held 'bajo' noun -> meter
;

Extend 'ataca' last
	* 'con' held -> atacar
	* creature 'con' held -> atacar
	* noun 'con' held -> cortar
	* 'a//'/'al' creature 'con' held -> atacar
	* 'a//'/'al' noun 'con' held -> cortar
;

extend 'cuenta' first
	* noun -> contar
;

Verb 'aparta' = 'empuja';
Verb 'comprale' = 'compra';
Verb 'h' = 'habla';
Verb 'c' = 'coge';
Verb 'd' = 'deja';
Verb 'v' = 'vende';

! -----------------------------------------------------------------------------
! Déjalo, es sólo decorado
! -----------------------------------------------------------------------------

class DecoradoBase
class Decorado
with
	antes [;
		examinar:
			rfalse;
		oler, tocar, probar:
			"Nada de especial.";
		coger, subir, girar, empujar, tirar, vaciar:
			"żVoecencia cree que eso podría servir realmente para algo?";
		buscarEn, meterse:
			"No serviría de nada.";
		default:
			"Me temo que no puedes hacer eso.";
	],
	reaccionar_antes [;
		tocar, probar, oler:
			if ( uno == obj_arriba ) {
				"Cómo vas a hacer eso... ˇNo puedes llegar hasta el cielo!";
			}
	]
;

class DecoradoCalle(10)
class DecoradoBase
with
	describir
     	'adoquines' "Sí, las calles están hechas de pavés." G_MASCULINO + G_PLURAL
     	'casas' "Varias casas bajas se apelotonan frente a la calle." G_FEMENINO + G_PLURAL
		'sol'   "Paso de mirar al sol directamente." 0
		'palacio' "El castillo se alza imponente, a cierta distancia." 0
		'castillo' "El castillo, cercano, se alza imponente." 0
		'muro' "La muralla se vé en algunas direcciones." 0
		'muralla' "La muralla se vé en algunas direcciones." G_FEMENINO
;

class DecoradoInteriorCueva(10)
class DecoradoBase
with
	describir
	          'apertura' "Comunica una cámara con otra." G_FEMENINO
	          'aperturas' "No, no hay más de una." G_FEMENINO + G_PLURAL
	          'cueva' "Oscura y húmeda." G_FEMENINO
	          'camara' "Oscura y húmeda." G_FEMENINO
	          'camaras' "Sí, la cueva está formada por varias cámaras." G_FEMENINO + G_PLURAL
		'paredes' "Húmedas." G_FEMENINO + G_PLURAL
		'pared' "Húmeda." G_FEMENINO
	,
	reaccionar_antes [;
		tocar, probar, oler:
			if ( uno == obj_arriba ) {
				"El techo, alto por encima de tu cabeza, es húmedo y huele a moho.";
			}
	]
;

class DecoradoMontePedregoso(10)
class DecoradoBase
with
	describir
	          'tierra' "Es más amarillenta por aquí, más pedregosa." G_FEMENINO
		'hojas' "Las hojas de los árboles son numerosas, ciertamente." G_FEMENINO + G_PLURAL
		'arboles' "Cada vez son más escasos." G_PLURAL
		'piedras' "Haylas por doquiera se mire." G_FEMENINO + G_PLURAL
		'arbustos' "Pequeńos arbustos." G_PLURAL
		'arbusto' "Pequeńos arbustos" G_PLURAL
		'maleza' "Pequeńos arbustos" G_FEMENINO
		'matas' "Por doquiera." G_FEMENINO + G_PLURAL
		'camino' "El camino, hollado mil veces, serpentea bajo tus pies." 0
		'senda' "En realidad es algo más grande, como un camino." G_FEMENINO
;

class DecoradoMonte(24)
class DecoradoBase
with
	describir
	          'tierra' "Oscura y fértil, tapizada de vida por doquier." G_FEMENINO
		'piedras' "Alguna hay." G_FEMENINO + G_PLURAL
		'camino' "El camino, hollado mil veces, serpentea bajo tus pies." 0
		'vereda' "En realidad es algo más grande, como un camino." G_FEMENINO
		'senda' "En realidad es algo más grande, como un camino." G_FEMENINO
;

class DecoradoBosque(24)
class ObjetoEstatico
with
	nombre_corto "bosque",
	genero G_MASCULINO,
	nombre_m 'bosque' 'arbusto',
	nombre_mp 'arboles' 'arbustos',
	nombre_f 'boveda' 'maleza',
	nombre_fp 'hojas' 'matas' 'hojas',
	descripcion "Muchos y muy tupidos árboles acompańan el camino. Sus hojas se entrelazan formando
	             una tupida bóveda, mientras en el suelo varios arbustos completan una bella escena."
;

