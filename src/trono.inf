! Constantes
Constant Historia "^El Trono de Inglaterra^";
Constant Titular  "O de como Ulfius obtiene la ayuda de Merlín...^^";
Constant HAY_CURIOSIDADES;
Constant NUM_MONEDAS_INICIALES = 20;
Constant MAX_RELOJES = 128;
Constant PUNTOS_LUGAR = 10;
Constant PUNTOS_OBJETO = 5;
Constant HAY_TAREAS;
Constant NUMERO_TAREAS = 9;
Release 2;

! Constantes para modificar el comportamiento del parser
Constant PUNTUACION_MAX = 118;
Constant ADMITIR_COMANDO_SALIDAS;

! Puntuación
Constant TAREA_CABALLERO_NEGRO = 0;
Constant TAREA_GALAHAD = 1;
Constant TAREA_ENCONTRAR_A_MERLIN = 2;
Constant TAREA_CONSEGUIR_MAPA = 3;
Constant TAREA_VOLVER_CON_MERLIN = 4;
Constant TAREA_ENTRAR_EN_TUNEL = 5;
Constant TAREA_COGER_LLAVE_MAESTRA = 6;
Constant TAREA_TERMINAR_AVENTURA = 7;
Constant TAREA_LLAVE_MERLIN = 8;

Array puntuacion_tareas ->
	9 ! caballero negro
	3 ! galahad
	6 ! encontrar a Merlín
	3 ! conseguir el mapa
	9 ! volver al castillo con Merlín
	3 ! entrar en el castillo
	6 ! llave maestra
	9 ! terminar la aventura
	3 ! Llave de merlín
;

[ ImprimirTareas cualTarea;
	switch( cualTarea ) {
		TAREA_CABALLERO_NEGRO: "por vencer totalmente al caballero negro";
		TAREA_GALAHAD: "por ayudar a Galahad";
		TAREA_ENCONTRAR_A_MERLIN: "por atravesar el laberinto";
		TAREA_CONSEGUIR_MAPA: "por conseguir el mapa del laberinto";
		TAREA_VOLVER_CON_MERLIN: "por volver al castillo de Westmorland con Merlín";
		TAREA_ENTRAR_EN_TUNEL: "por entrar en el castillo de Cornualles";
		TAREA_COGER_LLAVE_MAESTRA: "por conseguir la llave maestra";
		TAREA_TERMINAR_AVENTURA: "por terminar la misión completamente";
	}
];


Include "smw";

[ curiosidades;
	print (s_bold) "El Trono de Inglaterra^";

	print "^Escrita con la ayuda de:
			^ - InformATE! (por Graham Nelson, traducido y adaptado por Zak),
			^ - Jif (por Alessandro Schillaci y Mapache)
			^ - y txtMap.^";

	print "^Y la inestimable colaboración de:
			^ - Jenesis alias ~BetaTester~,
			^ - Yokiyoki.^";

	print (s_underline) "^http://caad.mine.nu/baltasarq/^";

	print "^^Uther Pendragón vivió varios ańos más, dedicando su reinado a luchar contra
	       los sajones. Finalmente, murió, probablemente debido a un envenenamiento provocado
	       por espías sajones. Tanto él como su hermano, que reinó antes que él, están enterrados,
	       según la leyenda, en Stonehenge, que fue trasladado en tiempos de Uther desde Irlanda.
	       ^^Locres es el nombre antiguo de lo que hoy se conoce como Reino Unido.
	       ^^Lady Ingrain se desposó con Uther; no se sabe si contenta o no, ni se sabe si le
	       guardó rencor por haber matado a su marido o no (porque efectivamente, las tropas de
	       Uther lo mataron cuando trataba de llegar hasta el castillo donde estaba Ingrain).
	       ^^El padre de Lady Ingrain fue, según otra leyenda,
	       José de Arimatea, quien se supone que tomó en un cáliz
	       la sangre de Jesús el Nazareno mientras le estaban crucificando. Éste es, de nuevo
	       supuestamente, el Santo Grial, perseguido por Arturo (el hijo de Uther e Ingrain)
	       hasta la extenuación, historia que entronca con multitud de leyendas
	       sobre sectas secretas, descritas profusamente en libros tan en boga en la
	       actualidad.
	";

	print "^^En cuanto a ciertos símbolos que aparece en el juego, decir que
	       ~arturo~ significa oso, mientras que el símbolo de los druídas era
	       una serpiente sin ojos ni boca, simbolizando las fuerzas telúricas
	       que salían de la tierra.^";

	print "^^Por cierto, Westmorland existe todavía en el reino unido.^";

	print "^^^Relato escrito durante el verano de 2005^^";
	print (s_underline) "...por Selena y
	       ^    Baltasar, el arquero.
	       ^
	       ^    selenavirtual@@64yahoo.com.ar
	       ^    baltasarq@@64gmail.com^^";
];

