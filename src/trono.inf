		if ( llave has oculto ) {
			give llave ~oculto;
			print "^Ves una curiosa llave brillando en el fondo del estanque.^";
		}
		"Es agua del estanque, cristalina, y fresca";
	],
	reaccionar_antes [;
		ponerSobre:
			"Meter cosas en el agua del estanque no parecería servir a ninguna finalidad.";
	],
	antes [;
		beber:
			"Sacias tu sed, y te sientes reconfortado.";
	]
has femenino;

ObjetoCortable arbustosEntradaLaberinto "arbustos" PIE_DE_LA_MONTANA
class ObjetoEstatico
with
	nombre 'arbustos',
	adjetivos 'tupidos' 'tupido',
	objetoCortante espada,
	alCortar "...la pared de arbustos cortada deja entrever ahora un hueco
	          por el que podrías pasar.",
	descripcion_cortado "Los aún tupidos arbustos
	                     dejan entrever ahora un hueco en el que
	                     podrías pasar...",
	descripcion_nocortado "Tupidos arbustos, que limitan con la muralla,
	                       impiden el paso hacia el este."
has nombreplural;

Objeto ARENA "arena" ABISMO
with
	articulo "un poco de",
	nombre 'arena',
	descripcion "Fina arena.",
	reaccionar_antes [;
		examinar:
			if ( uno == obj_abajo
			  && localizacion == ABISMO )
			{
			  if ( arena in jugador )
			  {
				"Es arena como la que ya tienes...";
			  }
			  else
			  if ( self has oculto ) {
			    give self ~oculto;
				"El suelo está lleno de arena que podrías coger en tus manos...";
			  }
			  else <<examinar self>>;
			}
	],
	antes [;
		tirar, dejar, lanzar, ponerA:
			give arena oculto;
			move self to ABISMO;

			if ( localizacion == ABISMO )
			{
				"La arena se ve lanzada y esparcida en el aire
				 por la acción del viento que sopla
				 por el estrecho desfiladero.";
			} else {
				"La arena cae y se pierde, esparcida por el suelo...";
			}
	]
has femenino oculto;

Objeto ARMADURA_DE_ACERO "armadura de acero" estanteria
with
	nombre 'armadura' 'acero' 'combate',
	descripcion "La armadura de combate es la utilizada a la hora de cargar a caballo o en torneos. Es muy resistente."
has prenda femenino ;

Objeto ARMADURA_DE_CUERO "armadura de cuero" estanteria
with
	nombre 'armadura' 'cuero',
	descripcion "Tu armadura de cuero. No protege demasiado, pero por otra parte es mucho más manejable que la de combate.",
	antes [;
		vestir:
			if ( self in jugador
			  && self hasnt puesto )
			{
				if ( ARMADURA_DE_ACERO in jugador
				  && ARMADURA_DE_ACERO has puesto )
				{
					print "^...te quitas ", (el) ARMADURA_DE_ACERO, " tan sólo un momento...^";
				}
			}
	]
has prenda femenino ;

DejadoDesaparecido BOLSA "bolsa de dinero" limbo
private
	numMonedas NUM_MONEDAS_INICIALES
with
	fueRobada false,
	nombre_m 'oro' 'dinero',
	nombre_f 'bolsa' 'monedas',
	genero G_FEMENINO,
	msgPerdida [;
			self.fueRobada = false;
			"^Desafortunadamente, la bolsa del dinero ha desaparecido...
			 żquién la habrá cogido?^
			 żqué dirá el Rey Uther de todo ésto?";
	],
	descripcion [;
		self.abrir();
		print " le echas un vistazo... tienes ", self.getNumMonedas(), " monedas de oro ";
		self.cerrar();
		rtrue;
	],
	getNumMonedas [;
		return self.numMonedas();
	],
	quitarMonedas [x;
		self.abrir();
		if ( x > self.getNumMonedas() )
		{
			x = self.getNumMonedas();
		}
		print " retiras ", x, " monedas.^";

		self.numMonedas = self.numMonedas - x;
		print "^Ahora te quedan ", self.numMonedas, " ";

		self.cerrar();
	],
	insertarMonedas [x;
		self.abrir();
		print " introduces ", x, " monedas más.^";
		self.numMonedas = self.numMonedas + x;
		print "Ahora tienes ", self.getNumMonedas(),
		      " monedas ";
		self.cerrar();
	],
	resetMonedas [;
		self.numMonedas = NUM_MONEDAS_INICIALES;
	],
	abrir [;
		print "^Abres la bolsa... ";
	],
	cerrar [;
		print " ...cierras la bolsa.^";
	],
	antes [;
		contar:
			<<examinar self>>;
		abrir:
			self.abrir();
			print " pero como no tienes nada que hacer ahora mismo con ella ";
			self.cerrar();
			rtrue;
		cerrar: "ˇLa bolsa ya está cerrada!";
		vaciar: "No sería una buena idea tener las monedas bailando
		         fuera de la bolsa.";
		buscarEn: <<examinar self>>;
	],
	despues [;
		dejar: self.lugarDondeLaDejaste = parent( self );
	]
has femenino ;

