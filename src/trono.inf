class DejadoDesaparecido
class Objeto
with
	prepararPerdibles [x;
		objectloop ( x ofclass DejadoDesaparecido ) {
			arrancarDaemon( x );
		}

		rtrue;
	],
	lugarDondeLaDejaste limbo,
	despues [;
		dejar: self.lugarDondeLaDejaste = parent( self );
		coger: self.lugarDondeLaDejaste = limbo;
	],
	msgPerdida "Aquí habías dejado algo...",
	daemon [;
		if ( self notin jugador
		  && parent( self ) ~= SALA_DEL_TRONO
		  && parent( self ) ~= ALMENAR
		  && parent( self ) ~= CASA_DE_ULFIUS
		  && parent( self ) ~= GUARIDA_DE_MERLIN
		  && parent( self ) ~= localizacion
		  && parent( self ) ~= limbo )
		{
			! Nos roban el objeto...
			! ˇno se puede dejar tirado por ahí!
			move self to limbo;
			return;
		}

		! Avisar de que la dejaste por aquí
		if ( self in limbo
		  && localizacion == self.lugarDondeLaDejaste )
		{
			self.lugarDondeLaDejaste = limbo;
			ImprimirOEjecutar( self, msgPerdida );
			return;
		}
	]
;

class ObjetoCortable
class Objeto
private
	cortado false,
with
	objetoCortante Nothing,
	estaCortado [;
		return self.cortado;
	],
	descripcion_cortado "Está entero.",
	descripcion_nocortado "Ha sido cortado.",
	alCortar "Ahora está cortado.",
	descripcion [;
		if ( self.estaCortado() ) {
				ImprimirOEjecutar( self, descripcion_cortado );
		}
		else		ImprimirOEjecutar( self, descripcion_nocortado );
	],
	antes [;
		cortar, atacar:
			if ( self.objetoCortante in jugador ) {
				self.cortado = true;
				print "Lanzas un par de tajos con tu espada...^";
				ImprimirOEjecutar( self, alCortar );
				rtrue;
			}
			else {
				"No tienes con qué cortar ", (el) self, "...";
			}
	]
;

class ConexionAbrible
class Conexion
with
	laLLave Nothing,
	antes [;
		echarcerrojo:
			if ( otro == self.laLLave ) {
				<<cerrar self>>;
			}

			"Me temo que no conseguirás cerrar ", (el) self, " con ", (el) otro, "...";
		quitarcerrojo:
			if ( otro == self.laLLave ) {
				<<abrir self>>;
			}

			"Me temo que no conseguirás abrir ", (el) self, " con ", (el) otro, "...";
	]
;

! ------------------------------ Objetos que no son personajes pero repre gente
class Gente
with
	nombre_corto "gente",
	genero G_FEMENINO,
	nombre_f 'multitud' 'gente',
	nombre_fp 'gentes',
	nombre_mp 'vecinos',
	nombre_m 'gentio',
	conversacion [;
		"No parecen interesados en tu conversación,
		 sino en sus propios quehaceres.";
	],
	antes [;
		escuchar: "Una gran cacofonía de múltiples conversaciones llega hasta
		           tus oídos.";
		examinar: rfalse;
		oler: "La higiene en nuestra época no es -ejem- ejemplar.";
		hablar, responder, preguntar: self.conversacion(); rtrue;
		default: "^ˇNo podéis hacer eso!";
	]
has estatico animado femenino;

! ================ Inicio ==================================================

[ inicializar;
	ModoMirar      = 2; ! Redescribir siempre
	Modo_Notificar = 0; ! No avisar de puntuación incrementada
	localizacion   = SALA_DEL_TRONO;


	cambiarJugador( Ulfius );

	bolsa.prepararPerdibles();	! Las clases no aceptan llamadas
	InicializarConexiones();	! Para las puertas
	iniciarDecorados();			! Los decorados, (pasar true para estadísticas)

	print "(Aquellos que jueguen por primera vez deben teclear
			'AYUDA' en el prompt: '>'.^Pulsa ENTER cuando veas:
			'...'.)";
	wait();
	clearMainWindow();

	cortoInicio.proyeccion();
	clearMainWindow();
];

! ================= LOCALIDADES ===============

MontePedregoso PLATAFORMA_ARRIBA "Plataforma pétrea"
with
	arriba [;
		print "Trepas trabajosamente, durante un tiempo
		       que se antoja eterno...^";
		jugadorA( CUMBRE, 2 );
		rtrue;
          ],
	abajo [;
		print "Destrepas trabajosamente, durante un buen rato...^";
		jugadorA( ABISMO, 2 );
		rtrue;
	],
	descripcion
		"La roca ha esculpido caprichosamente una ancha cornisa en este punto.
		 La vista es espectacular, pues la altura es ahora ya considerable, hasta el
		 punto de que notas frío. Más arriba, la cumbre nevada otorga un extrańo
		 colofón a la yerma piedra."
	,
;

MontePedregoso CUMBRE "Cumbre"
with
    adentro ATALAYA,
    al_e ATALAYA,
    arriba "Se podría seguir ascendiendo brevemente un pequeńo risco que sobrepasa
            esta cumbre, pero no tendría mayor interés, y además, apenas hay asideros.",
    abajo [;
		print "^Destrepas trabajosamente, cuidándote de no desasirte de
		       las fisuras de la roca.^";
		jugadorA( PLATAFORMA_ARRIBA, 2 );
		rtrue;
    ],
    descripcion
	"El paisaje desde aquí es impresionante, dejando ver las altas montańas,
	 también nevadas, en lontananza. Al este, ligeramente retirada del
	 abismo, una pequeńa atalaya domina los pasos de la sierra."
;

ObjetoEstatico cumbreFalsa "cumbre" CUMBRE
with
    esta_en ABISMO CUMBRE PLATAFORMA_ARRIBA ATALAYA,
    nombre 'cumbre' 'pico',
    descripcion
        "La cumbre es yerma, nevada a trozos dispares.",
    antes [;
        examinar: rfalse;
        default: "No sería de gran utilidad.";
    ]
has oculto;

ObjetoEstatico paisajeAbismo "paisaje" CUMBRE
with
    esta_en ABISMO CUMBRE PLATAFORMA_ARRIBA ATALAYA,
    nombre 'paisaje' 'vista',
    descripcion
        "El paisaje es realmente impresionante. La sierra se domina desde
         aquí arriba.",
    antes [;
        examinar: rfalse;
        default: "No sería de gran utilidad.";
    ]
has oculto;

ObjetoEstatico falsaAtalaya "atalaya" CUMBRE
with
    nombre 'atalaya' 'construccion' 'torre' 'garita' 'ventanales' 'ventanal'
           'columnas' 'columna',
    esta_en CUMBRE ATALAYA,
    descripcion
        "Es una pequeńa, aunque robusta, construcción de piedra. Grandes ventanales,
         separados por estrechas columnas, conforman su cuerpo.",
    reaccionar_antes [;
        meterse:
            if ( uno == self ) {
                <<entrar>>;
            }
    ]
has oculto;

Laberinto ATALAYA "Atalaya"
with
    al_o CUMBRE,
    afuera CUMBRE,
    descripcion
        "El interior es tan frío e iluminado como el exterior,
         pues los muros están compuestos por amplios ventanales separados por
         estrechas columnas. En el suelo, cercano a uno de los muros, puedes
         ver un bulto con forma humana, descansando sobre el suelo."
;

respondeUnaVez pensamientosSobreGalceran
private
    elementos
        "~ˇDios mío!~, piensas, ~otro amigo perdido~."
        "Piensas: ~żˇPor qué!?, o, mejor, żpara qué?~"
        "~żEs éste el destino de un caballero, sucumbir de frío y dejado de la
         mano de Dios, tratando de cumplir una caprichosa misión cuyo resultado,
         si aún ventajoso para el reino, nadie puede predecir?~ - Te preguntas."
        "~ˇNo es justo morir así, y encima por nada!~ - Casi lo dices en voz
         alta, apretando los puńos."
        "~żQué puede impulsar a una persona racional a llevar a sus caballeros
         más preciados a la muerte?~ - Te preguntas."
        "~Cedería gustoso mi puesto en esta misión. Ojalá pudiera renunciar a
         toda esta sinrazón, y vagar lejos...~ - A pesar de todo, en tu interior
         te recuerdas a ti mismo que estás al servicio del Rey."
;

ObjetoEstatico cadaver "cadáver" ATALAYA
with
    nombre 'cadaver' 'galceran' 'caballero' 'bulto'
           'hombre' 'persona' 'humano' 'humana' 'forma',
    descripcion [;
        print "Se trata de Galcerán, caballero del rey. O lo que queda de él,
               en realidad. El cadáver está grotescamente congelado, y Galcerán,
               descubres aliviado, muestra un rostro tranquilo y relajado, con
               los ojos cerrados.^^";

        print (string) pensamientosSobreGalceran.dev_msg(), "^";
    ],
    antes [;
        examinar: rfalse;
        default: "Será mejor dejar que Galcerán descanse en paz.";
    ]
;

MontePedregoso ABISMO "Abismo"
private
	puente false,
with
	descripcion " El camino	 termina aquí abruptamente, si bien parece que podría seguir, más estrecho,
				 hacia el norte.
				 El suelo, que hasta ahora era pedregoso,
				 es extrańamente arenoso aquí. Ante tí, hacia el norte,
				 puedes ver lo que parece ser otra montańa,
				 desgraciadamente demasiado lejos como para saltar.
				 Hacia arriba, puedes ver una pared de roca, con algunos asideros que hacen
				 posible escalarla.
				 A tus pies, un pronunciado desfiladero se abre amenazador.",
	arriba [;
		print "^Con dificultad, te agarras a los pocos asideros que encuentras,
		       y vas haciendo tu viaje hacia arriba.^";
		jugadorA( PLATAFORMA_ARRIBA, 2 );
		rtrue;
	],
	abajo "Tras considerarlo, decides no hacerlo. Hay muchas más posibilidades
	       de ascender que de descender con éxito.",
	al_n [;
		if ( self.puente ) {
			print "^Cruzas dificultosamente por donde estaba el puente
			 que entreviste con la ingestión de la seta...^";
      		jugadorA( ENTRADA_A_LA_CUEVA      		, 2 );
      		rtrue;
		}
		else "ˇˇTe matarías!!";
	],
	al_o CAMINO_ENTRE_DESFILADEROS,
	mostrarPuente [;
		self.puente = true;

		"tu sorpresa es mayúscula al ver
		aparecer un puente colgante delante de ti, entre la bruma.
		Un extrańo y repentino sabor
		a cacahuetes parece inundar tu boca...^^
		El efecto se pasa y todo parece normal... no hay ningún
		puente colgante a la vista, o eso es lo que parece...";
	]
;

ObjetoEstatico cieloFalso "estrellas" ABISMO
with
	esta_en ABISMO CAMINO_ENTRE_DESFILADEROS CUMBRE PLATAFORMA_ARRIBA ATALAYA,
	nombre_m 'sol' 'cielo',
	nombre_f 'estrella' 'luna',
	nombre_fp 'estrellas',
	genero G_FEMENINO + G_PLURAL,
	descripcion "El cielo comienza a oscurecerse mientras las estrellas, pequeńos alfileres de
	             luz, aparecen. La luna, aunque pálida, parece querer entrar en escena.",
	antes [;
		tocar, probar, oler:
			"Obviamente, no puedes hacer eso.";
	],
	reaccionar_antes [;
		examinar:
			if ( uno == obj_arriba ) {
				<<examinar self>>;
			}
	]
;

ObjetoEstatico elAbismo "abismo" ABISMO
with
	esta_en ABISMO CAMINO_ENTRE_DESFILADEROS PLATAFORMA_ARRIBA CUMBRE
	        ENTRADA_A_LA_CUEVA,
	nombre_m 'risco' 'abismo''vacio' 'desfiladero' 'saliente'
	         'escarpado' 'fondo',
	nombre_f 'fisura' 'pared' 'piedra' 'roca' 'pendiente' 'escarpada',
	genero G_MASCULINO,
	descripcion "Un profundo vacío de paredes de fría y lisa roca, se extiende a tus pies.
	             No se ve el fondo. En realidad, la pared continúa tanto hacia abajo
	             como hacia arriba.",
	antes [;
		saltarsobre, meterse: "No puedes saltar tan lejos...";
	],
	reaccionar_antes [;
		subir, trepar:
		 	<<ir obj_arriba>>;
		bajar:
		    <<ir obj_abajo>>;
		ponerSobre, lanzar:
			if ( uno == estanteria
			  && otro == self )
			{
				move estanteria to limbo;
				"Colocas la estantería atravesando el abismo, pero
				no es lo suficientemente
				larga. El tablón cae rápidamente en el oscuro abismo,
				hasta que ya
				no se distingue a la vista. Momentos después, oyes un lejano golpe.
				Perdida está...";
			}
			else
			if ( otro == self ) {
				"No quiero perder ", (el) uno, "...";
			}

	]
;

ObjetoEstatico laCornisa "cornisa" ABISMO
with
    esta_en ABISMO PLATAFORMA_ARRIBA,
	nombre_m 'saliente',
	nombre_f 'cornisa' 'plataforma' 'petrea',
	genero G_FEMENINO,
	descripcion [;
		<examinar elAbismo>;
		"Permaneces, casi colgado sobre el abismo, en un estrecho saliente.";
	]
;


ExteriorPalacio ALMENAR "Almenar"
with
	descripcion " Desde aquí se ve la pequeńa villa de Westmorland, protegida por la muralla exterior, a los pies de este castillo. Hacia el sur, se encuentran los campos de cultivo que sustentan a las gentes del lugar, mientras que hacia el norte un corto espacio dedicado a campos antecede al bosque, para terminar en las lejanas montańas. En ese terreno no se puede ir a caballo.",
	abajo PATIO_DE_ARMAS,

;

ObjetoEstatico BosqueFalsoAlmenar "bosque" ALMENAR
with
          esta_en ALMENAR PUERTA_NORTE PUERTA_SUR CAMPOS_DE_CULTIVO CAMINO,
	nombre 'bosque' 'arboles' 'paisaje',
	descripcion "El bosque se antoja, incluso desde aquí, frondoso y húmedo."
;

ObjetoEstatico VillaFalsaAlmenar "villa" ALMENAR
with
          esta_en ALMENAR PUERTA_NORTE PUERTA_SUR CAMPOS_DE_CULTIVO CAMINO,
	nombre 'villa' 'pueblo' 'westmorland' 'ciudad'
	       'poblacion' 'paisaje' 'castillo' ,
	descripcion "La villa se arracima alrededor del castillo."
has femenino;

ObjetoEstatico MontanaFalsaAlmenar "montańas" ALMENAR
with
          esta_en ALMENAR PUERTA_NORTE PUERTA_SUR CAMPOS_DE_CULTIVO CAMINO,
	nombre 'montana' 'montanas' 'paisaje',
	descripcion "De las lejanas montańas casi no se aprecia ningún detalle."
has femenino nombreplural;

CasaMadera CABANA "Cabańa"
with
	descripcion " El ambiente de la cabańa es casi lúgubre, y muy húmedo.
	             Dos de las cuatro paredes están cubiertas de estanterías,
	             mientras que las otras dos se dividen entre una pequeńa zona de estar y una cocina.
	             Bastones, estantes con hierbas y varios frascos están distribuidos
	             por todo el lugar. Un anciano, sentado en su mecedora, te mira con interés.",
	afuera CLARO_DEL_BOSQUE,
	al_s CLARO_DEL_BOSQUE
;

ObjetoEstatico cabanaFalsa "cabańa" CABANA
with
    nombre 'cabana' 'casa',
    antes [;
        examinar: << mirar >>;
        default: "No conseguirás nada así.";
    ]
;

Calle CALLE_AL_ESTE_DE_LA_PLAZA "Calle al este de la plaza"
with
	descripcion " Esta calle es el extremo del pueblo amurallado.
	              En esta zona es donde suelen vivir los campesinos.
	              Sabes que la concurrida plaza se encuentra al oeste, mientras
	              que al norte hay más calles.",
	al_n CALLE_AL_NORESTE_DE_LA_PLAZA,
	al_o PLAZA_DEL_CASTILLO,
	no_puedes_ir "La calle discurre de oeste a norte mediante una suave curva.
	              Al oeste, se encuentra la plaza principal, la del castillo,
	              mientras que al norte conecta con otra calle con un pequeńo
	              cruce.",
;

ObjetoEstatico puebloWestmorlandFalso "pueblo" CALLE_AL_ESTE_DE_LA_PLAZA
with
    esta_en CALLE_AL_ESTE_DE_LA_PLAZA CALLE_AL_NORESTE_DE_LA_PLAZA,
    nombre 'pueblo' 'villa' 'calle' 'calles' 'callejones' 'callejon',
    descripcion
        "Las calles del pueblo son irregulares y estrechas.",
    antes [;
        examinar: rfalse;
        default: "Me temo que nada bueno se obtendría así.";
    ]
;

Calle CALLE_AL_NORESTE_DE_LA_PLAZA "Calle al noreste de la plaza"
with
	descripcion " En esta calle se encuentra tu casa, en la que podrías entrar.
	              Hacia el norte, se asienta una de las puertas de la villa, así
	              como una calle parte hacia el sur.
	              Hacia el este puedes ver la muralla del pueblo.",
	al_n PUERTA_NORTE,
	al_s CALLE_AL_ESTE_DE_LA_PLAZA,
	al_so PLAZA_DEL_CASTILLO,
	adentro CASA_DE_ULFIUS,
          no_puedes_ir "Al norte la calle muere en una de las puertas de la villa,
                        mientras al sur entronca con una calle que realiza un suave
                        giro hacia el norte. Puedes entrar en tu casa."
;

Laberinto CALLEJON "Callejón"
with
	descripcion " Un callejón sin salida sólo te permite ir hacia el este. Lo cierto es que no puedes garantizar que éste sea el este, estás ya muy desorientado.",
	al_e CRUCE_EN_EL_LABERINTO_1,
;

Laberinto CALLEJON_2 "Callejón"
with
	descripcion [;
		print " Un callejón que sólo permite la salida hacia el sur.
		       Si es que es el sur, claro, pues a estas alturas estás ya muy desorientado";

		if ( hiedraCallejon2.estaCortado() ) {
			print ". Hacia el norte, podrías pasar por un hueco entre las hiedras";
		}

		".^";
	],
	al_n [;
		if ( hiedraCallejon2.estaCortado() )
		{
			print "^...pasas a través de la hiedra...^";
			jugadorA( CALLEJON_DE_LA_PUERTA, 2 );
			rtrue;
		}
		"No puedes ir por ahí.";
	],
	al_s CRUCE_EN_EL_LABERINTO_2,
;

Laberinto CALLEJON_DE_LA_FUENTE "Callejón de la fuente"
class Habitacion
with
	descripcion [;
		print " Al final del corredor, observas una fuente con agua.
		  El laberinto es igual de desolado aquí que en el resto de las estancias."
		;

		if ( PUERTA_CALLEJON_FUENTE hasnt oculto ) {
			print " Hacia el norte ves una puerta.";
		}

		"^";
	],
	al_o CALLEJON_DE_LA_PUERTA,
	al_n PUERTA_CALLEJON_FUENTE,
;

! [Si abres esta puerta, te verás devuelto a la primera intersección]

Laberinto CALLEJON_DE_LA_PUERTA "Callejón de la puerta"
with
	descripcion " El callejón se extiende hacia el norte, con una enorme puerta,
				 que altera el aspecto de este monótono laberinto, como final.
	              La única salida alternativa se abre al este.",
	al_s [;
		print "^...pasas a través de la hiedra...^";
		jugadorA( CALLEJON_2, 2 );
		rtrue;
	],
	al_e CALLEJON_DE_LA_FUENTE,
;

Monte CAMINO "Camino"
with
	descripcion " El camino ancho y cómodo lleva hacia el bosque, al norte. Al sur, puedes ver, cercana, la villa. Estás solo en este camino, que viene de la entrada del bosque, de donde la gente suele contar extrańos (y escalofriantes) cuentos.",
	al_n ENTRADA_DEL_BOSQUE,
	al_s PUERTA_NORTE,
;

Monte CAMINO_NORESTE "Camino Noreste"
with
	descripcion " El camino se interna en el bosque húmedo, hacia el norte, mientras hacia el suroeste parece abrirse en un claro. La maleza es húmeda, y hace frío aquí. Los árboles, robles todos ellos, apenas dejan pasar la luz.",
	al_n CONTINUACION_DEL_CAMINO,
	al_so ENTRADA_DEL_BOSQUE,

;

Monte CAMINO_NOROESTE "Camino Noroeste"
with
	descripcion " El camino se interna en el denso bosque hacia el norte, mientras aparentemente sale hacia alguna parte al sureste.",
	al_n [;
		caballeroNegro.ponVieneDeLoc( self );
		jugadorA( POZO, 2 );
		rtrue;
	],
	al_se ENTRADA_DEL_BOSQUE,

;

Monte CAMINO_NORTE "Camino Norte"
with
	descripcion [;
	    print " El camino se presenta tranquilo. Todo está muy calmo.
	            Tal vez las historias del bosque que escuchaste
	            fueron sólo obras de algún Caballero fabulador.";
	    if ( ~~( jugador.fueMerlinEncontrado	    () ) ) {
	        print "^Avanzas esperanzado de encontrar lo antes posible a Merlín.";
	    }

	    "^";
	],
	al_n CIENAGA,
	al_s ENTRADA_DEL_BOSQUE,

;

MontePedregoso CAMINO_DE_LAS_MONTANAS "Camino de las montańas"
with
	descripcion " Tomas el camino, que al poco se torna en pedregoso. La tierra es amarilla aquí y los árboles abandonan poco a poco la escena. El camino asciende hacia las montańas, al norte, mientras al sur, en el valle, puedes ver la taberna.",
	eliminarNochePendiente [;
		PararReloj( self );
	],
	al_n [;
		ArrancarReloj( CAMINO_ENTRE_DESFILADEROS, 20 );
		jugadorA( CAMINO_ENTRE_DESFILADEROS, 2 );

		print "^El sol cae lentamente,
	              mientras las primeras estrellas comienzan a dejar ver
	              su brillo, anunciando
	              que la noche no llegará mucho más tarde.^";

		rtrue;
	],
	al_s TABERNA
;

ObjetoEstatico tabernaLejanaFalsa "taberna" camino_de_las_montanas
with
    esta_en camino_de_las_montanas camino_entre_desfiladeros,
    nombre 'taberna' 'valle' 'westmorland' 'pueblo' 'villa' 'aldea' 'poblacion',
    descripcion
        "Enclaustrada en el valle al sur, la taberna se ve como una mota marrón
         en una inmensidad verde. En el horizonte, casi adivinas Westmorland.
         Al sureste, distingues otra pequeńa aldea que desconoces.",
    antes[;
        examinar: rfalse;
        default: "Extrańa decisión... si bien imposible.";
    ]
;

ObjetoEstatico montanasFalsas "montańas"
with
    esta_en CAMINO_DE_LAS_MONTANAS TABERNA CAMINO_A_SAJONES1
            CAMINO_A_SAJONES2 ABISMO CAMINO_DE_LAS_MONTANAS
            CAMINO_ENTRE_DESFILADEROS PLATAFORMA_ARRIBA CUMBRE ATALAYA
            PIE_DE_LA_MONTANA,
    nombre_m 'paisaje',
    nombre_f 'montana' 'sierra',
    nombre_fp 'montanas',
    genero G_FEMENINO + G_PLURAL,
    descripcion "Próximas; altas y frías, se te antojan como enormes guardianes.",
    antes [;
        examinar: rfalse;
        default: "No conseguirás nada así. De verda, de verdad que no.";
    ]
has femenino;

ObjetoEstatico arboles_camino_montanas "árboles" CAMINO_DE_LAS_MONTANAS
private
	primeraVezSeta true,
with
	genero G_MASCULINO + G_PLURAL,
	nombre_mp 'arboles',
	nombre_m 'arbol',
	descripcion [;
	    print "Los árboles, aunque ya escasos, dan buena sombra";

		if ( seta in parent( self )
		  && seta has oculto )
		{
			give seta ~oculto;
			if ( self.primeraVezSeta ) {
				 print " y... debajo de uno de ellos, hay una seta... que jurarías
			 		   no haber visto antes";
			 	 self.primeraVezSeta = false;
			}
			else print " y... debajo de uno de ellos hay más setas (que asegurarías
			            que no estaban allí antes...), una es (o eso
			            jurarías), exactamente igual a la anterior";
		}

		".^";
	]
has nombreplural;

! [Desde aquí hasta entrar en la cueva, tienes un número de turnos restringido]

MontePedregoso CAMINO_ENTRE_DESFILADEROS "Camino entre desfiladeros"
with
	tiempo_restante 0,
	tiempo_agotado [;
		if ( localizacion == self
		  || localizacion == CAMINO_DE_LAS_MONTANAS
		  || localizacion == ABISMO
		  || localizacion == TABERNA )
		{
			print "^^...cae la noche...^^";
			print "Te apresuras a llegarte hasta la taberna";
			wait( "...^" );
			print "^Entras y le pides alojamiento al cantinero";
			wait( "...^" );

			jugadorA( INTERIOR_DE_LA_TABERNA, 2 );

			jugador.decir( "ˇHola! ...me ha sorprendido la noche y..." );
			cantinero.decir( "Quedaos esta noche si lo deseais." );

			print "^Descansais como podéis durante la noche...^";
			jugador.hacerPasarUnDia();

			rtrue;
		}
	],
	descripcion " De a poco avanzas por el camino
	              que serpentea hacia las montańas.
	              Continúa hacia el este,
	              mientras que al sur desciende hacia el valle.
	              El camino es rocoso, abierto por un lado,
	              la escarpada pendiente por el otro.
	             ",
	al_s CAMINO_DE_LAS_MONTANAS,
	al_e ABISMO,

;

Monte CAMPOS_DE_CULTIVO "Campos de cultivo"
with
	descripcion " Los campos de cultivo sustenta a los habitantes de la villa.
	              Magníficos en tiempo de siembra,
	              se extienden hacia el este y sur aparentemente sin fin. Pronto brotará el trigo.
	              El suelo del camino es también de tierra blanda.",
	al_n PUERTA_SUR,
	no_puedes_ir "No hay nada que hacer por aquí. Sabes que tus objetivos se encuentran
	              más hacia el norte.",
;

object tierra "tierra" CAMPOS_DE_CULTIVO
with
	nombre 'tierra' 'fresca',
	descripcion [;
		print "La tierra es fresca, recientemente removida...^";

		if ( cuchillo in limbo ) {
			move cuchillo to parent( self );
			"Encuentras un pequeńo cuchillo semienterrado en la tierra.";
		}

		rtrue;
	],
	reaccionar_antes [;
	    excavar:
	        	if ( cuchillo in limbo ) {
        	        print "Te dispones a excavar, pero entonces te fijas en el suelo.^";
	            <<examinar self>>;
	         } else "El suelo es realmente blando, no es necesario cavar.";
		examinar:
			if ( uno == obj_abajo ) {
				<<examinar self>>;
			}
	]
has estatico oculto femenino;

! [Viaje en carruaje. Narración. Merlín viaja con ellos.]

LocalidadConLuz CARRUAJE "Carruaje"
private
	llegado false,
with
	descripcion [;
		if ( ~~self.llegado ) {
			arrancarReloj( self, 5 );
			print "^Notas una gran desazón en tu interior. Realmente
			       empiezas a tener dudas sobre la moralidad de esta
			       misión. Quizás Merlín querrá ahora responder a tus
			       preguntas.^";
		}

		"Los caballos tiran del lujoso carruaje.
		 A tu lado, Merlín y Uther viajan silenciosos.
		 Uther parece emocionado y apesadumbrado a la vez.
		 Merlín te devuelve la mirada cuando te fijas en él,
		 incluso cuando está aparentemente dormitando
		 abre los ojos y posa su mirada en ti,
		 con ese extrańo brillo que siempre percibes.";
	],
	tiempo_restante 0,
	tiempo_agotado [;
		self.llegado = true;
		print "^El carruaje se detiene.
		       Habéis llegado por fin al objetivo: el castillo donde
		       Lady Ingrain, ajena a todo, está supuestamente a salvo
		       de Uther Pendragón.^Las tropas del Rey han puesto sitio
		       al castillo, así que entrar no será fácil";
		wait( "...^" );
	],
	bajar [;
		if ( self.tiempo_restante == 0
		  && self.llegado )
		{
			print "Os disponéis a bajar del carruaje, y Merlín
			       y Uther os siguen";
			wait( "...^" );
			print "El carruaje se aleja rápidamente una vez habéis descendido...^";

			move merlin to SUROESTE_DEL_CASTILLO;
			move uther to SUROESTE_DEL_CASTILLO;
			jugadorA( SUROESTE_DEL_CASTILLO, 2 );
			jugador.ponMisionEnCornualles();

			merlin.decir( "Mi seńor, tomad esta poción. Cambiará vuestro
			               aspecto para que parezcáis el mismísimo Duque
			               de Cornualles, aunque por muy breve tiempo." );
			print "^Merlín alarga un frasco hacia Uther...^";

			merlin.decir( "Ulfius, debéis escoltar al Rey, sin que sufra dańo
			               alguno hasta los dormitorios de Lady Ingrain, en
			               el interior del castillo. Al norte, econtraréis un
			               embarcadero... aguardad hasta que llegue un
			               hombre de mi confianza, que os proveerá de algunos
			               objetos útiles en vuestra misión."
			);

			uther.decir( "Os sigo, Ulfius." );
			rtrue;
		}
		else "ˇEl coche está en marcha!";
	],
	afuera [; return self.bajar(); ],
	abajo [; return self.bajar(); ],
	! Al principio, no se podrá salir, hasta que termine el viaje
;

ObjetoEstatico carruajeFalso "carruaje" CARRUAJE
with
    nombre 'carruaje' 'paisaje' 'vista' 'bancos' 'banco' 'ventana' 'ventanilla'
           'ventanas' 'ventanillas' 'coche' 'carroza',
    descripcion
        "El carruaje es lujoso, formado por dos bancos enfrentados donde os sentáis
         los pasajeros de este extrańo viaje a inciera misión. Por las ventanas, pueds
         ver pasar el paisaje rápidamente.",
    antes [;
        examinar: rfalse;
        default: "No tendría utilidad práctica.";
    ]
;

! [ aquí tiene que encontrar sus cosas, entre ellas, un par de armaduras, la de cuero y la de combate, más pesada. Será interesante programar una ciénaga en el bosque donde, si portas la armadura de combate, te hundas irremediablemente]
CasaMadera CASA_DE_ULFIUS "Casa de Ulfius"
with
	descripcion " Tu casa es pequeńa pero acogedora. No tiene varias estancias como las más modernas, pero es suficiente, sobre todo considerando el tiempo que realmente pasas en ella. ",
	afuera CALLE_AL_NORESTE_DE_LA_PLAZA,
	descansar [;
		print "^Esperas descansar, acostado, aunque te cuesta dormir...^";
		print "No puedes evitar cierto desasosiego cuando piensas en tu misión,
		       en si tiene sentido, si merece la pena";

		wait( "...^" );
		jugador.hacerPasarUnDia();
		wait( "...^" );
		clearMainWindow();
		<< mirar >>;
	]
;

ObjetoEstatico casaPropiaFalsa "casa" CASA_DE_ULFIUS
with
    nombre 'casa' 'estancia' 'estancias' 'sala',
    esta_en CASA_DE_ULFIUS TU_NUEVA_CASA,
    descripcion [;
        << mirar >>;
    ],
    antes [;
        examinar: rfalse;
        default: "No conseguirás nada así.";
    ]
;

Objeto estanteria "estantería" CASA_DE_ULFIUS
with
	nombre 'estanteria' 'balda',
	descripcion "Una estantería, un tanto polvorienta.",
	antes [x;
		coger:
			if ( self has estatico ) {
				"La estantería es sólida, aunque tirando de ella, se podría arrancar...";
			}
		tirar, empujar, arrancar:
			print "^Empiezas a tirar de la estantería...^";

			objectloop ( x ) {
				if ( x in estanteria ) {
					move x to CASA_DE_ULFIUS;
					print (_El) x, " cae al suelo...^";
				}
			}

			print "Después de algún esfuerzo, arrancas la estantería de la pared...^";

			move self to jugador;
			give self ~estatico;
			give self ~soporte;
			rtrue;
	]
has estatico soporte femenino;

Objeto mesaCasaUlfius "mesa" CASA_DE_ULFIUS
with
	nombre 'mesa',
	descripcion "Pues sí, una típica mesa de madera."
has estatico soporte femenino;

Objeto camaCasaUlfius "cama" CASA_DE_ULFIUS
with
	nombre 'cama',
	descripcion "Pues sí, una típica cama de madera con lecho de paja.",
	reaccionar_antes [;
		dormir:
		        return CASA_DE_ULFIUS.descansar();
	]
has estatico soporte femenino;

! [Aquí estaría la ciénaga de la que hablabas, en caso de llevar puesta una armadura pesada]

Monte CIENAGA "Ciénaga"
private
	primeraVezAtravesada true,
with
	atravesarCienaga [destino;
		print "^No te queda más remedio que atravesar la ciénaga...^";
		print "Cuando comienzas a atravesar la ciénaga,
		       notas como tus pies se hunden más y más en el barro";
		wait( "...^" );
		print "Sigues hundiéndote, ya casi no avanzas";
		wait( "^...^" );

		if ( children( jugador ) < 2
		  && ARMADURA_DE_ACERO notin jugador )
		{
			self.ponHaSidoAtravesada();
			print "...afortunadamente, cruzas la ciénaga a salvo...^
			       ˇPor muy poco!^";
			jugadorA( destino, 2 );
		}
		else {
			if ( self.noHaSidoAtravesada() ) {
				print "Te das cuenta de que no vas a poder atravesarla,
				       y retrocedes...^A salvo, de milagro...^";
			}
			else {
				banderaFin = 1;
				print "^...no vas a llegar... no vas a llegar...^
				       ...no llegas.^"
				;
				wait( "...^" );
				print "^Tu último pensamiento es para tu Rey y tu misión...^
				       fallida.^"
				;
			}
		}
	],
	noHaSidoAtravesada [;
		return self.primeraVezAtravesada;
	],
	ponHaSidoAtravesada [;
		self.primeraVezAtravesada = false;
	],
	descripcion " El camino permite avanzar de norte a sur, si bien
	 			 se ve interrumpido repentinamente por una gran ciénaga en el extremo norte.
	              Aunque la ciénaga es relativamente estrecha en cuanto a lo largo,
	              no puedes ver su final ni a derecha ni a izquierda. ",
	al_n [;
		self.atravesarCienaga( CLARO_DEL_BOSQUE );
		rtrue;
	],
	al_s CAMINO_NORTE
;

ObjetoEstatico laCienaga "ciénaga"
with
	nombre_f 'cienaga' 'laguna',
	nombre_m 'lago' 'barro' 'agua',
	nombre_fp 'aguas',
	genero G_FEMENINO,
	esta_en CIENAGA CLARO_DEL_BOSQUE,
	descripcion "La ciénaga se vé embarrada y, al menos en las orillas, poco profunda.
			Parece que se podría cruzar allí donde interrumpe el camino.",
	antes [;
		beber: "...no seas guarro...";
	],
	reaccionar_antes [;
		saltar, saltarSobre, meterse:
			"En lugar de dar inútiles botes, y otras maniobras extrańas,
			quizás deberías probar a dirigirte tranquilamente hacia
			el norte.";
		ponerSobre, lanzar:
			if ( uno == estanteria
			  && otro == self )
			{
				move estanteria to limbo;
				"Colocas la estantería atravesando la ciénaga, pero
				no es lo suficientemente
				larga. El tablón se hunde lentamente en la burbujeante ciénaga,
				hasta que ya
				 no queda nada de ella a la vista. Perdida está...";
			}
			else
			if ( otro == self ) {
				"No quiero perder ", (el) uno, "...";
			}
	]
has femenino;

Monte CLARO_DEL_BOSQUE "Claro del bosque"
with
	descripcion " El claro se abre justamente enfrente a una tosca,
	              aunque fuerte, cabańa de madera.
	              Unas pequeńas volutas de humo ascienden
	              desde la chimenea hasta el cielo. Hacia el sur,
	              parte un camino que resulta ser la única salida del claro.
	              Desde aquí, es posible ver como el camino del sur se ve
	              interrumpido por la ciénaga.",
	al_s [;
		CIENAGA.atravesarCienaga( CIENAGA );
		rtrue;
	],
	adentro CABANA,
	al_n CABANA
;

ObjetoEstatico claroBosqueCabana "claro del bosque" CLARO_DEL_BOSQUE
with
          genero G_MASCULINO,
	nombre_m 'claro',
	nombre_f 'apertura',
	descripcion
	    "En su centro hay una cabańa, y en uno de sus extremos, una ciénaga.",
	antes [;
		examinar: rfalse;
		default: "Nada útil obtendrías de eso.";
	]
;

ObjetoEstatico edificacionMadera "casa de madera"
with
	nombre 'casa' 'madera' 'cabana' 'chimenea' 'construccion',
	esta_en TABERNA CLARO_DEL_BOSQUE,
	descripcion "Está hecha de grandes y fuertes troncos de madera. Pese a que es un poco
	             tosca, está claro que es fuerte y resistente. De la chimenea salen unas
	             volutas de humo.",
	antes [;
		meterse: <<entrar>>;
	]
has femenino;

! [Aquí podría funcionar "xyzzy" y tener una visión de Merlín]
Monte COLINA "Colina"
with
	descripcion " El camino asciende hacia el noreste,
	              donde el túnel arbóreo parece terminar en una mágica luz...
	              allí los árboles se espacian, dejando claros entre ellos.
	              En sentido contrario, desciende hacia el sur,
	              donde los árboles parecen formar una bóveda sólo
	              atravesada por tenues alfilerazgos de luz proyectados
	              en el suelo. No es posible pasar por este lugar sin
	              apreciar su mágica esencia."
	,
	al_s [;
		caballeroNegro.ponVieneDeLoc( self );
		jugadorA( POZO, 2 );
		rtrue;
	],
	al_ne TABERNA,

;

! [Aquí estan los bandidos]

Monte CONTINUACION_DEL_CAMINO "Continuación del camino"
with
	descripcion "  El camino sigue de sur a norte. La sensación de húmedad es cierta aquí. Los árboles comienzan a formar una tupida bóveda, mientras la luminosidad desciende. Escuchas ruidos entre los árboles... tal vez sea el viento.",
	al_n LAGO,
	al_s CAMINO_NORESTE,

;

Laberinto CRUCE_EN_EL_LABERINTO_1 "Cruce en el laberinto"
with
	descripcion " Aquí se entrecruzan varios caminos. Los altos muros permiten salidas al norte, este, oeste y sur.",
	al_n CRUCE_EN_EL_LABERINTO_3,
	al_s ENTRADA_AL_LABERINTO	,
	al_e CRUCE_EN_EL_LABERINTO_1,
	al_o CALLEJON,

;

Laberinto CRUCE_EN_EL_LABERINTO_2 "Cruce en el laberinto"
with
	descripcion " Aquí se entrecruzan varios caminos. Los altos muros permiten salidas al norte, este, oeste y sur.",
	al_n CALLEJON_2,
	al_s CRUCE_EN_EL_LABERINTO_1,
	al_e CRUCE_EN_EL_LABERINTO_4,
	al_o CALLEJON,

;

Laberinto CRUCE_EN_EL_LABERINTO_3 "Cruce en el laberinto"
with
	descripcion " Aquí se entrecruzan varios caminos. Los altos muros permiten salidas al norte, este, oeste y sur.",
	al_n CALLEJON,
	al_s CRUCE_EN_EL_LABERINTO_1,
	al_e CRUCE_EN_EL_LABERINTO_4,
	al_o CRUCE_EN_EL_LABERINTO_3,

;

Laberinto CRUCE_EN_EL_LABERINTO_4 "Cruce en el laberinto"
with
	descripcion " Aquí se entrecruzan varios caminos. Los altos muros permiten salidas al norte, este, oeste y sur.",
	al_n CRUCE_EN_EL_LABERINTO_1,
	al_s CRUCE_EN_EL_LABERINTO_3,
	al_e CALLEJON,
	al_o CRUCE_EN_EL_LABERINTO_2,

;

InteriorCueva CUEVA "Cueva"
with
	descripcion " Efectivamente es una cueva,
				 un tanto pequeńa y húmeda, pero suficiente
				 como para albergarte y guarecerte. Parece continuar hacia el este.",
	al_o ENTRADA_A_LA_CUEVA	,
	al_e CUEVA_PROFUNDA,
	afuera ENTRADA_A_LA_CUEVA,
;

InteriorCueva CUEVA_PROFUNDA "Cámara"
with
	descripcion " La pared desnuda de la cueva te envuelve. La cámara donde te encuentras es enorme,
	              si bien no se puede destacar nada de ella.
	              El suelo está igual de desnudo, de no ser por la ocasional huella de un antiguo excremento
	              de murciélago. La apertura por la que entraste aquí se encuentra al oeste.
	              Unos restos humanos reposan contra una de las paredes de la cueva.",
	al_o CUEVA
;

ObjetoEstatico excrementos "excrementos" CUEVA
with
    esta_en CUEVA CUEVA_PROFUNDA,
    genero G_MASCULINO + G_PLURAL,
    nombre_m 'excremento' 'murcielago',
    nombre_f 'caca',
    nombre_mp 'excrementos' 'muercielagos',
    nombre_fp 'cacas',
    descripcion
        "Asquerosa y pestilente caca de murcielago.",
    antes [;
        examinar: rfalse;
        default: "ˇNo seas guarro, que es caca, déjala estar!";
    ]
;

ObjetoEstatico esqueleto "esqueleto" CUEVA_PROFUNDA
with
	nombre_mp 'restos' 'humanos' 'humanoides',
	nombre_m 'enano' 'maluva' 'esqueleto',
	nombre_f 'hacha' 'arma',
	nombre_fp 'hachas' 'armas',
	genero G_MASCULINO + G_PLURAL,
	descripcion "Los restos de un humano, si bien extremadamente cortos en cuanto a
	             estatura, reposan contra una de las paredes de la cámara.
	             A su lado, firmemente sujetas por las manos del esqueleto, reposan
	             sendas hachas, herrumbosas por el paso del tiempo.",
	antes [;
	          probar, oler, tocar:
	                  "ˇUn poco de respeto por Maluva!";
		coger, buscarEn, tirar, empujar, girar:
			"Es... era... el enano Maluva. No puedes observar sus restos sino con
			 veneración, y desde luego, no te atreves a profanarlos.";
	]
;

! [De noche, la salida al norte no se verá, de día sí]
MontePedregoso ENTRADA_A_LA_CUEVA "Explanada en la roca"
private
	haDescansado false,
	puedeSeguir false,
with
	resetYendo [;
		self.puedeSeguir = false;
		self.haDescansado = false;
	],
	resetViniendo [;
		if ( jugador.fueMerlinEncontrado() )
				self.puedeSeguir = false;
		else		self.puedeSeguir = true;

		self.haDescansado = true;
	],
	ponPuedeSeguir [;
		self.puedeSeguir = true;
	],
	sePuedeSeguir [;
		return self.puedeSeguir;
	],
	descripcion [;
		print " El camino avanza sinuoso, rodeando esta nueva montańa.
		  Siempre, a cada uno de tus lados, encuentras el abismo
		  y la escarpada pared de roca.
		  El camino parece finalizar, de nuevo abruptamente,
		  en una pequeńa explanada.
		  Puedes ver, hacia el este, una abertura en la pared.";
		if ( self.sePuedeSeguir() ) {
			print " Una pequeńa vereda serpentea hacia el norte...";
		}

		print "^";

		if ( ~~self.haDescansado ) {
			self.haDescansado = true;

			print "^Ha caído la noche. Decides meterte en la cueva...^";
			jugadorA( CUEVA, 2 );
			print "El día termina de desvanecerse, gradualmente,
			        entre las montańas,
			        como el agua que se retira con la marea.
			        Ya no se puede ver nada.^";
			print "^Duermes profundamente, tratando de descansar después
			       de todo lo que has pasado...^";
			jugador.hacerPasarUnDia();

			if ( ~~self.sePuedeSeguir() )
			{
				if ( bolla in jugador
				  || bolsaDeComida in jugador )
				{
					print "^Te alimentas lo mejor que puedes...^";

					if ( bolla in jugador ) {
						move bolla to limbo;
						print "...devoras la bolla de pan...^";
					}

					if ( bolsaDeComida in jugador ) {
						lucrius.reset(); ! La comida vuelve a ser comprable
						print "...comes la comida seca que traías...^";
					}

					self.puedeSeguir = true;
					CAMINO_DE_LAS_MONTANAS					.eliminarNochePendiente();
				}
				else "^...no tienes nada que comer... es necesario
				      que te avitualles...";
			}
		}
	],
	al_n [;
		if ( self.sePuedeSeguir() ) {
			if ( ~~jugador.fueMerlinEncontrado() )
				print "^...reemprendes la marcha.^";
			else 	print "^...vuelves hacia el laberinto.^";

			jugadorA( PIE_DE_LA_MONTANA, 2 );
			rtrue;
		}
		else "No es el momento de ir hacia las montańas, no estás preparado...";
	],
	al_s [;
		print "^Cruzas dificultosamente por donde estaba el puente
	  		    que entreviste con la ingestión de la seta...^";
		jugadorA( ABISMO, 2 );
		rtrue;
	],
	al_e CUEVA,
	adentro CUEVA,
has valepuntos;

ObjetoEstatico explanadaRoca "explanada" ENTRADA_A_LA_CUEVA
with
    nombre 'explanada' 'superficie' 'abertura' 'entrada' 'cueva' 'gruta'
           'camino' 'senda' 'vereda',
    descripcion [;
        print "Pues sí, una superficie más o menos llana de roca, que cubre el lugar donde
         debiera estar el camino.
         En uno de sus extremos puedes ver una abertura en la pared, pareciendo
         la entrada de una cueva.";

        if ( ENTRADA_A_LA_CUEVA.sePuedeSeguir() ) {
            print " Una vereda parte hacia el norte.";
        }

        "^";
    ],
    antes [;
        meterse: << ir obj_e >>;
        examinar: rfalse;
        default: "No llevaría a ningún resultado útil.";
    ]
;

Laberinto ENTRADA_AL_LABERINTO "Entrada al laberinto"
with
	descripcion [;
		ENTRADA_A_LA_CUEVA.resetViniendo();
		" Ante ti un largo callejón de altos muros, te lleva hacia el norte.";
	],
	al_n CRUCE_EN_EL_LABERINTO_1,
	al_s PIE_DE_LA_MONTANA,
	afuera PIE_DE_LA_MONTANA,

;

ObjetoEstatico callejuelaLaberinto "callejón" ENTRADA_AL_LABERINTO
with
    esta_en ENTRADA_AL_LABERINTO CRUCE_EN_EL_LABERINTO_1 CRUCE_EN_EL_LABERINTO_2
            CRUCE_EN_EL_LABERINTO_3 CRUCE_EN_EL_LABERINTO_4 CALLEJON
            CALLEJON_DE_LA_FUENTE CALLEJON_DE_LA_PUERTA TUNEL,
    nombre 'callejon' 'calle' 'callejuela' 'paso' 'camino' 'pasaje' 'corredor'
           'estancia' 'laberinto' 'estancias' 'tunel',
    descripcion
        "Los pasajes se suceden en varias direcciones.",
    antes [;
        examinar: rfalse;
        default: "No serviría de nada, me temo.";
    ]
;

Monte ENTRADA_DEL_BOSQUE "Entrada del bosque"
with
	descripcion " La linde del bosque está aquí, luciendo una pasmosa frondosidad que contrasta
				 con el cielo abierto del valle.
	              El bosque parece aceptar a regańadientes el camino que hollas, el cual se interna
	              en su espesura, proveniente del sur. Su extremo norte aparece, en realidad,
	              dividido en tres nuevas sendas, hacia el norte, noreste y noroeste.",
	al_n CAMINO_NORTE,
	al_s CAMINO,
	al_ne CAMINO_NORESTE,
	al_no CAMINO_NOROESTE,

;

! [Aquí hay como diez objetos, inservibles excepto para mapear el laberinto]

LocalidadConLuz ESPACIO_ENTRE_LOS_ARBUSTOS "Espacio entre los arbustos"
with
	descripcion " Un pequeńo espacio entre los arbustos,
	              apenas suficiente para poder mantenerse de pie.
	              Es una casi coqueta bóveda vegetal, con una tenue luz
	              de tonos verdes.",
	salirDeAqui [;
		print "^...sales a la luz del día a través de los arbustos cortados ...^";
		jugadorA( PIE_DE_LA_MONTANA, 2 );
		rtrue;
	],
	al_o [; return self.salirDeAqui(); ],
	afuera [; return self.salirDeAqui(); ],
;

! [Ańadamos un toque de humor: habrá un felpudito, y bajo él, la llave de la puerta]

Habitacion EXPLANADA_DE_LA_ROCA "Explanada de la roca"
with
	descripcion " Una amplia explanada empedrada,
	              tiene como centro la roca que se veía desde la
	              entrada del laberinto, con una forma vaga de oso,
	              grande y majestuoso.",
	al_s TUNEL,
	al_n PUERTA_EXPLANADA_DE_ROCA,
has valepuntos;

ObjetoEstatico explanadaFalsa "explanada" EXPLANADA_DE_LA_ROCA
with
    nombre 'explanada' 'superficie',
    antes [;
        examinar: << mirar >>;
        default: "No solucionaría gran cosa.";
    ]
;

Habitacion GUARIDA_DE_MERLIN "Guarida de Merlín"
class InteriorCueva
with
	descripcion [;
		ArrancarReloj( self, 3 );
		" La guarida no es más que una cueva; sin embargo, algún tipo de luz cuyo origen desconoces parece brotar de las paredes, proveyendo de una agradable semi-penumbra. La puerta de acceso, a tu espalda, es la única posible salida, pues no hay otras estancias o escaleras. Puedes ver una mesa, un viejo sillón, una biblioteca con innumerables volúmenes, y finalmente una chimenea. Se antoja demasiado escueto, incluso para un druída.";
	],
	tiempo_restante 0,
	tiempo_agotado [;
		if ( ~~jugador.fueMerlinEncontrado() )
		{
			if ( localizacion ~= self ) {
				return;
			}

			jugador.ponMerlinEncontrado();

			print "Un sonido sordo y repentino atraen toda tu atención...^
				Tras una pequeńa nube de humo, que se disipa lentamente,
				un anciano se encuentra delante de ti.^
				Lleva una túnica, ajustada mediante un cinto, una sandalias,
				y un bastón por toda vestimenta.
				Su mirada denota inteligencia, y te mira entre divertido y curioso.^";
			wait( "...^" );

			Merlin.decir( "Veo que encontrasteis el camino." );

			print "^...se adelanta, comentando muy relajado. Su mirada
					se posa en ti, mientras crees ver un extrańo brillo
					en sus ojos.^";

			jugador.decir( "Vos... sois... żSois Merlín?" );

			Merlin.decir( "Yo soy." );

			Merlin.pasaANombrePropio();

			print "^Sientes una intensa emoción y alivio... ˇpor fin!^";

			jugador.decir( "El rey Uther me envía,
			                una gran pena reside en su alma, y..."
			);

			Merlin.decir( "Uther... claro que sí.
			             Pero es conveniente que vengais a hablar
			             conmigo en persona."
			);

			jugador.decir( "żEn persona?"	);

			Merlin.decir( "Me encuentro ante vos sólo en espíritu.
						  Mi verdadero hogar es el bosque cercano
						  a la villa del rey. Una pequeńa cabańa
						  al norte de la entrada del bosque."
			);

			print "^Te sientes confuso...^";
			jugador.decir( "Pero yo no os he encontrado allí..." );

			Merlin.decir( "Me encontraréis, me encontraréis...
			               esta vez me encontraréis.
			               Acudid a mi y hablaremos."
			);

			print "^Merlín desaparece, dejando otra pequeńa nube de humo tras
			       de sí.^";
			wait( "...^" );

			Merlin.decir( "ˇAh...! Por favor, cerrad la puerta con llave
			               cuando os vayais, y dejadla bajo el felpudo..."
			);

			if ( POCION_PARA_INVISIBLE notin jugador ) {
				Merlin.decir( "...y tomad, un poco de poción verde..." );
				move POCION_PARA_INVISIBLE to jugador;
				Merlin.decir( "...es útil para combatir algún caballero
				               que otro... pero eso vos ya lo sabéis..." );
				print "Una poción verduzca aparece entre tus manos...
				       ^Se oye una risa ahogada que reverbera en esta
				        guarida...";
				wait( "^" );
				print "Después, todo queda en silencio...^";

				rtrue;
			}

			jugador.ponMerlinEncontrado();
		}
	],
	al_s PUERTA_EXPLANADA_DE_ROCA,
has valepuntos;

ObjetoEstatico sillonGuarida "sillón" GUARIDA_DE_MERLIN
with
	nombre 'sillon',
	descripcion "Un viejo sillón.",
	antes [;
	    examinar: rfalse;
	    meterse: "No es el momento de descansar, ahora.";
	    default: "Deja el sillón tranquilo, no es importante.";
	]
;

ObjetoEstatico guaridaFalsa "guardia" GUARIDA_DE_MERLIN
with
	nombre 'estancia' 'guarida' 'casa' 'sala' 'habitacion',
	descripcion [;
	    print "En semipenumbra. Húmeda. A ver...^";
	    << mirar >>;
	],
	antes [;
	    examinar: rfalse;
	    default: "Incluso tú dudas de que hacer eso fuera útil.";
	]
;

ObjetoEstatico librosGuarida "biblioteca" GUARIDA_DE_MERLIN
with
	nombre_mp 'libros' 'volúmenes',
	nombre_f 'biblioteca' 'estanteria',
	nombre_m 'libro',
	descripcion "Multitud de volúmenes se agolpan en las estanterías de las paredes.",
	genero G_FEMENINO,
has femenino;

CasaMadera INTERIOR_DE_LA_TABERNA "Interior de la Taberna"
private
	cerrada false,
with
	estaCerrada [;
		return self.cerrada;
	],
	descripcion [;
		print " El lugar no está demasiado animado; sólo
	             el cantinero,
	             detrás del mostrador
	             (aparentemente muy ocupado en sus quehaceres)";

	    if ( tristan notin limbo ) {
	             print ", y un hombre muy joven con aspecto de haberse
	             bebido todo el licor a la venta,
	             apoyado en el otro extremo del mostrador";
	    }

	    ".";
	],
	afuera [;
		if ( seta notin jugador
		  && cantinero.fueMerlinComentado() )
		{
			print "^El cantinero se dirige a tí cuando te vas.";
			cantinero.decir(
				"Recordad, caballero, que quien a buen árbol se arrima..."
			);
		}

		print "^Empujas la puerta de la taberna...^";
		jugadorA( TABERNA, 2 );
		rtrue;
	]
;

ObjetoEstatico tabernaInteriorFalsa "taberna" interior_de_la_taberna
with
    nombre 'local' 'taberna' 'casa' 'sala' 'estancia',
    descripcion [; << mirar >>; ],
    antes [;
        examinar: rfalse;
        oler, probar, tocar: "No es que sea una pocilga, pero no es un alarde
                              de limpieza aqueste lugar.";
        default: "No creo, amable jugador, que tal cosa sirviera de mucho.";
    ]
;

ObjetoEstatico mostrador "mostrador" INTERIOR_DE_LA_TABERNA
with
	nombre_m 'mostrador',
	nombre_f 'barra',
	genero G_MASCULINO,
	descripcion [;
		print "Una limpia, aunque ya gastada, barra.^";

		if ( cantinero.objetoAVender == bolla ) {
			print "En uno de los extremos, protegida por un pequeńo mostrador, puedes ver
			       una bolla de pan que debe estar a la venta.^";
		}

		if ( tristan.estaOfreciendoMapa() ) {
			print "Sobre ella, puedes ver un pergamino, bien vigilado sin embargo, por ",
					(el) tristan, "^";
		}
	]
has transparente;

ObjetoEstatico copas "copas" INTERIOR_DE_LA_TABERNA
with
	nombre_fp 'copas',
	nombre_mp 'vasos',
	genero G_FEMENINO + G_PLURAL,
	descripcion "Sí, son copas."
;

! [aquí podría funcionar xyzzy, proporcionándote una vision de Merlín o algo]

Monte LAGO "Lago"
with
	descripcion " El camino desemboca en una amplia zona sin árboles,
	              donde puedes ver también un lago.
	              A pesar de estar bastante alejados, sobre ti el cielo
	              es casi indiscernible. El lago, al este,
	              parece transformar el bosque en un pantano.
	              La humedad es casi palpable aquí,
	              mientras que la escasa luz que se filtra entre
	              las hojas se refleja en la superficie del lago,
	              y, a la vez, se ve proyectada en la bóveda arbórea.
	              Es imposible pasar por aquí sin detenerse
	              a apreciar tan mágico efecto. "
	,
	al_s CONTINUACION_DEL_CAMINO,
	al_no TABERNA,

;

ObjetoEstatico elLago "lago" LAGO
with
	nombre_m 'lago' 'pantano',
	nombre_f 'laguna' 'charca' 'agua',
	nombre_fp 'aguas' 'pantanosas',
	descripcion "El lago del lago no es transparente, sino que se vé llena de una miríada de
	             partículas, que le confieren un tono verdoso. Sin embargo, el agua sugiere
	             frescura.",
	reaccionar_antes [;
		nadar:
			"Decir que sabes nadar sería decir mucho, aunque aprovechas para chapotear un poco
			 y mojar los pies en el agua -lo cual relaja mucho-.";
		entrar:
			print "Te adentras un poco en el lago...^";
			<<nadar>>;
	],
	antes [;
		meterse:
			print "Te adentras un poco en el lago...^";
			<<nadar>>;
		tocar:
			"La temperatura del agua del lago es muy agradable... está casi tibia al tacto...";
	]
;

! [Al intentar ir a otras salidas se le responde que no se puede deambular libremente por palacio]

Palacio PASILLO_PRINCIPAL "Pasillo Principal"
with
	descripcion " El pasillo principal de palacio, cuyo arco principal, al norte,  permite acceder a la sala del trono, mientras al sur se encuentra el patio de armas.  Hay otras salidas al este, y al oeste. ",
	al_n SALA_DEL_TRONO,
	al_s PATIO_DE_ARMAS,
!	al_s [;
	!	banderafin = 2;
		!"Fin de la demo^^Ésto es todo por ahora...
	!	 si te has quedado con ganas de saber y jugar más, espera a la MedievoComp...^
	!	 ^^
	!	 El trono de Inglaterra... más de 20 personajes, más de 60 localidades.
	!	 ^^";
!	],
	no_puedes_ir "No puedes deambular libremente por palacio. Sabes que el rey te castigaría si te sorprendieran."
;

ExteriorPalacio PATIO_DE_ARMAS "Patio de armas"
with
	descripcion " En el patio de armas se entrenan y forman los otros caballeros del rey, tus compańeros. Se puede salir del castillo por la puerta principal. También se puede acceder a las almenas por las escaleras para realizar vigilancia.",
	al_n PASILLO_PRINCIPAL,
	arriba ALMENAR,
	afuera PLAZA_DEL_CASTILLO,
	al_s PLAZA_DEL_CASTILLO,
;

ObjetoEstatico patioArmas "patio de armas" PATIO_DE_ARMAS
with
    nombre 'patio' 'armas',
    descripcion
        "El patio es una gran superficie que se extiende entre las murallas
         y los arcos que conducen al exterior y al pasillo principal.",
    antes [;
        examinar: rfalse;
        default: "No conseguirás nada así. De verdad.";
    ]
;

ObjetoEstatico escaleras "escaleras" PATIO_DE_ARMAS
with
	nombre 'escaleras' 'piedra',
	esta_en ALMENAR PATIO_DE_ARMAS,
	descripcion "Las escaleras conducen hasta el almenar.",
	antes [;
		meterse:
			if ( localizacion == PATIO_DE_ARMAS ) {
				<<subir>>;
			} else "ˇNo se puede subir más!";
		bajar:
			if ( localizacion == ALMENAR ) {
				<<bajar>>;
			} else "No se puede bajar más.";
	]
;

ObjetoEstatico puertaPpalCastillo "puerta principal" PATIO_DE_ARMAS
with
    esta_en PATIO_DE_ARMAS PLAZA_DEL_CASTILLO,
    nombre 'puerta' 'principal' 'arco' 'rastrillo' 'arcos',
    descripcion "Un gran arco vacío con el rastrillo colgando en su parte superior,
                 sin bajar, lo cuál siempre te recuerda por alguna razón a unas
                 terribles fauces de algún tipo.",
    antes [;
        examinar: rfalse;
        default: "El rastrillo y el arco principal son demasiado grandes.";
    ]
;

MontePedregoso PIE_DE_LA_MONTANA "Pie de la montańa"
with
	descripcion [;
		print " Estás al pie de la montańa... a lo lejos observas una enorme roca.
	     La montańa no es ya abrupta, puedes apreciar algo de maleza por aquí.
	     Justo delante de ti, ves un muro y una entrada en el mismo, cuyo dintel
	     exhibe una extrańa figura. "
	    ;

	    if ( arbustosEntradaLaberinto.estaCortado() )
	    		"Un hueco entre tupidos arbustos se sitúa al este.";
	    else	"Hacia el este, puedes ver unos tupidos arbustos.";
	],
	al_e [;
		if ( arbustosEntradaLaberinto.estaCortado() ) {
		     print "^...pasas a través de los arbustos cortados...^";
			jugadorA( ESPACIO_ENTRE_LOS_ARBUSTOS, 2 );
			rtrue;
		}
		<<examinar arbustosEntradaLaberinto>>;
	],
	adentro ENTRADA_AL_LABERINTO,
	al_n ENTRADA_AL_LABERINTO,
	al_s ENTRADA_A_LA_CUEVA
;

ObjetoEstatico rocaOso "roca" PIE_DE_LA_MONTANA
with
	nombre 'roca',
	descripcion "Es increíble, pero... ˇJurarías que tiene forma de oso!",
	antes [;
		probar, tocar, oler:
			"Está demasiado lejos.";
	]
has femenino;

ExteriorPalacio PLAZA_DEL_CASTILLO "Plaza del castillo"
with
	descripcion " La villa bulle de actividad. El rastrillo del castillo desemboca en una amplísima plaza, donde se sitúa siempre el mercado.  Desde aquí parten calles hacia el noreste, este y el sur ... en el resto de direcciones la muralla del pueblo bloquea el paso.",
	al_s PUERTA_SUR,
	al_e CALLE_AL_ESTE_DE_LA_PLAZA,
	al_ne CALLE_AL_NORESTE_DE_LA_PLAZA,
	al_n PATIO_DE_ARMAS,
	adentro PATIO_DE_ARMAS,
;

ObjetoEstatico plaza "plaza" PLAZA_DEL_CASTILLO
with
	nombre_f 'plaza',
	nombre_m 'pueblo' 'calle',
	nombre_fp 'calles',
	genero G_FEMENINO,
	descripcion "La plaza del castillo casi siempre está concurridisima, ya que es el lugar
	  			donde se organiza el mercado, y el centro neurálgico del pueblo, al partir de ella
	  			varias calles que lo estructuran."
;


! [Transitas atentamente... hasta que te encuentras con el caballero negro]

Monte POZO "Pozo"
with
	descripcion " El camino se abre tímidamente en una pequeńa pradera.
			Sin embargo, no parece haber ninguna vivienda por aquí,
			aunque sí hay, curiosamente, un pozo.
			Junto al pozo, en un pequeńo charco formado por una fuente,
			pace tranquilamente un caballo.
			Un caballero está de pie junto al caballo.
	",
	al_n COLINA,
	al_s CAMINO_NOROESTE,
;

ObjetoEstatico pradera "pradera" POZO
with
	esta_en POZO TABERNA,
	nombre_f 'pradera' 'hierba',
	nombre_m 'prado' 'claro' 'pasto' 'campo',
	genero G_FEMENINO,
	descripcion "La pradera se extiende hasta el límite del bosque, que la rodea."
;

Calle PUERTA_NORTE "Puerta norte"
with
	descripcion " La puerta norte de la villa. Puedes ver los muros del castillo hacia el sur, sabes que rodeándolo se llega al mercado. Hacia el norte, vas al bosque.",
	al_n CAMINO,
	al_s CALLE_AL_NORESTE_DE_LA_PLAZA,
          no_puedes_ir "La puerta de la villa separa las calles al sur del camino hacia
                        el bosque, al norte."
;

Calle PUERTA_SUR "Puerta sur"
with
	descripcion " Esta vía abandona el pueblo hacia el sur. Sin embargo, no te interesa ir en esa dirección, puesto que sabes que Merlín vive en el bosque situado al norte.",
	al_n PLAZA_DEL_CASTILLO,
	al_s CAMPOS_DE_CULTIVO,
          no_puedes_ir "La puerta de la villa separa los labradíos, al sur, de las casas
                        intramuros, al norte."
;

Palacio SALA_DEL_TRONO "Sala del Trono"
with
	descripcion " La sala del trono es abrumadoramente espaciosa. El trono se sitúa en  el  centro de la pared norte, mientras las paredes laterales se cubren con ricos tapices rememorando antiguas batallas ganadas por el rey. En el suelo, una alfombra roja conduce hasta el rey (si bien nadie se atrevería a llegar hasta él), y a los lados se sitúan los cortesanos. Delante de ti, se encuentra el rey Uther. Estás aquí por requerimiento suyo.",
	al_s PASILLO_PRINCIPAL,
	afuera PASILLO_PRINCIPAL,
	no_puedes_ir "La única forma de salir es encaminarse hacia el sur."
;

ObjetoEstatico decoradoSalaTrono "decorado" SALA_DEL_TRONO
with
	nombre 'tapices' 'alfombra' 'tapiz' 'alfombras' 'trono' 'adornos' 'adorno',
	descripcion
		"Ricos adornos cubren la sala. El Rey se sienta sobre un trono dorado, mientras que las paredes
		 se subren con tapices de batallas contra los sajones. Una gran alfombra cubre todo el
		 suelo de la estancia."
;

Monte CAMINO_A_SAJONES1 "Camino"
with
	descripcion "Este transitado camino gira en una amplia curva de este a
	             suroeste, serpenteando entre las faldas de las montańas.
	             Pareciera como si por aquí transitaran grandes
	             carromatos. Quizás al final del camino se encuentre un
	             importante centro de mercadeo.",
	al_so TABERNA,
	al_e CAMINO_A_SAJONES2
;

Monte CAMINO_A_SAJONES2 "Camino"
with
	descripcion "La senda corre de este a oeste. Hacia el este, puedes ver
	             en lontananza, una pequeńa aldea.
	             Aunque las montańas están cercanas, el terreno es llano aquí,
	             y puedes ver campos cultivados todo a tu alrededor.",
	al_o CAMINO_A_SAJONES1,
	al_e [;
		arrancarReloj( sajones, 5 );
		jugadorA( ALDEA_SAJONES, 2 );
		rtrue;
	]
;

ObjetoEstatico aldeaFalsa "aldea" CAMINO_A_SAJONES2
with
          nombre 'pueblo' 'villa' 'poblacion' 'poblado' 'aldea',
          descripcion "Una pequeńa villa enclaustrada entre montańas, al este.",
          antes [;
              examinar: rfalse;
              default: "No pareciera que aquesto pudiera ser útil.";
          ]
;

ObjetoEstatico campos "campos cultivados" CAMINO_A_SAJONES2
with
          esta_en CAMINO_A_SAJONES2 CAMPOS_DE_CULTIVO,
	nombre 'campos' 'cultivados' 'cultivo' 'cultivos',
	descripcion
		"Los ves por doquiera que mires, con diferentes tonos de verde
		 según el tipo de cereal o legumbre plantado en ellos."
has nombreplural;

Calle ALDEA_SAJONES "Aldea"
with
	al_o [;
		pararReloj( sajones );
		jugadorA( CAMINO_A_SAJONES2, 2 );
		rtrue;
	],
	descripcion
		"Una gran plaza sirve de vía de comunicación entre algunas
	             pequeńas casas. La plaza bulle de actividad, con numerosos
	             clientes del mercadillo de turno."
;

ObjetoEstatico mercadillo "mercadillo" ALDEA_SAJONES
with
	nombre_m 'mercado' 'mercadillo' 'ropaje' 'calle' 'callejon',
	nombre_mp 'calles' 'callejones' 'puestos' 'vestidos' 'ropajes',
	nombre_f 'ropa' 'plaza',
	genero G_MASCULINO,
	descripcion
		"En la plaza del pueblo, donde confluyen las dos o tres escasas
		calles que lo forman, se organiza el mercadillo.
		Todo lo que se vende en este mercadillo resultan ser artículos
		de vestir, lo cual no te interesa demasiado."
;

respondeUnaVez descSajones
private
	elementos
		"Una multitud de clientes del mercadillo se arremolina alrededor
		 de los puestos. Cuando los miras con detenimiento, te das
		 cuenta de que se trata de sajones."
		"La multitud parece muy entretenida con el mercadillo, aunque de
		 vez en cuando cazas alguna mirada furtiva hacia ti."
		"Los sajones empiezan a revolverse, inquietos. Multitud de caras
		 miran haca ti, más pendientes de tu persona que de las viandas en
		 los puestos."
;

Gente sajones "sajones" ALDEA_SAJONES
class ObjetoEstatico
with
	tiempo_restante 5,
	tiempo_agotado [;
		if ( ~~jugador.esInvisible() ) {
		  if ( localizacion == parent( self ) )
		  {
			banderafin = 1;

			"Los sajones te rodean. Se han dado cuenta de que eres un
		 	 britano. No hay escapatoria.";
		  }
		} else {
				arrancarReloj( self, 5 );
				"Un grupo de sajones armados y organizados aparecen entre la multitud...
		        sin duda, iban a por ti, pero ahora son incapaces de verte. Pese a su confusión,
		        no cabe duda de que irán a por ti en cuanto a te localicen.^
		        Parece incluso como si ya estuvieran advertidos de la posibilidad de tu llegada...";
		}
	],
	nombre_mp 'sajones' 'clientes',
	genero G_MASCULINO + G_PLURAL,
	descripcion [;
		print (string) descSajones.dev_msg(), "^";
	],
	antes [;
		escuchar: "Escuchas retazos de cortas conversaciones en las que
		           interviene la palabra ~britano~.";
	],
	reaccionar_antes [;
		escuchar:
			if ( uno == Nothing ) {
				<<escuchar self>>;
			}
	],
;

Monte TABERNA "Taberna"
with
	descripcion " En medio de la pradera, puedes ver un taberna.
				La gran casa se ve reconfortada por los rayos del sol,
				que debe calentarla agradablemente entre
				tanta humedad del bosque.
				De la pradera parten muchos caminos: de entre ellos,
				dos, el sureste y suroeste, se internan en el bosque,
				mientras que al norte parte un camino que lleva
				hacia las montańas. Un camino muy transitado al noreste
				llama tu atención.",
	al_n CAMINO_DE_LAS_MONTANAS	,
	al_so COLINA,
	al_se LAGO,
	al_ne CAMINO_A_SAJONES1,
	adentro [;
		if ( ~~INTERIOR_DE_LA_TABERNA.estaCerrada() ) {
			print "^Abres la puerta sin dificultad y
			       entras en el interior de la taberna...^";
			jugadorA( INTERIOR_DE_LA_TABERNA, 2 );
		}
		else print "^En este momento, la taberna está cerrada...^";

		rtrue;
	],
	no_puedes_ir "Ese camino no te interesa para tu misión."
;

ObjetoEstatico tabernaFalsa "taberna" TABERNA
with
	nombre_f 'taberna',
	nombre_m 'establecimiento',
	genero G_FEMENINO,
	antes [;
		examinar: <<examinar edificacionMadera>>;
		meterse: <<entrar>>;
	]
;



Habitacion TUNEL "Túnel"
class InteriorCueva
with
	descripcion " Ésto tiene más aspecto de ser una cueva alargada, un tosco túnel que contrasta con la suave perfección del laberinto. Tus pasos hacen eco en el lugar... ves una luz al final del túnel, hacia el norte, y también hay claridad hacia el sur.",
	al_n EXPLANADA_DE_LA_ROCA,
	al_s PUERTA_CALLEJON_FUENTE,
;

